@page
@model Client_Frontend.Pages.ManagerHomeModel
@{
    ViewData["Title"] = "Manager Home";
    Layout = "_ManagerLayout";
}

<div class="manager-page">
    <div class="app-grid">
        <section class="card">
            <h3>Warehouses</h3>
            <div class="list-item">
                <div style="display:flex;justify-content:space-between;align-items:center">
                    <div>
                        <strong>North Warehouse</strong>
                        <div><small>Address: 123 North St</small></div>
                    </div>
                    <div><small>Stock: 1,240</small></div>
                </div>
            </div>
            <div class="list-item">
                <div style="display:flex;justify-content:space-between;align-items:center">
                    <div>
                        <strong>Central Warehouse</strong>
                        <div><small>Address: 10 Central Ave</small></div>
                    </div>
                    <div><small>Stock: 3,520</small></div>
                </div>
            </div>
            <div class="list-item">
                <div style="display:flex;justify-content:space-between;align-items:center">
                    <div>
                        <strong>South Warehouse</strong>
                        <div><small>Address: 78 South Rd</small></div>
                    </div>
                    <div><small>Stock: 860</small></div>
                </div>
            </div>
        </section>

        <section class="card">
            <h3>Employees</h3>
            <div class="list-item">
                <div style="display:flex;justify-content:space-between;align-items:center">
                    <div>
                        <strong>Jane Doe</strong>
                        <div><small>Role: Worker</small></div>
                    </div>
                    <div><small>Assigned: Central</small></div>
                </div>
            </div>

            <div class="list-item">
                <div style="display:flex;justify-content:space-between;align-items:center">
                    <div>
                        <strong>John Smith</strong>
                        <div><small>Role: Worker</small></div>
                    </div>
                    <div><small>Assigned: North</small></div>
                </div>
            </div>

            <div class="list-item">
                <div style="display:flex;justify-content:space-between;align-items:center">
                    <div>
                        <strong>Mai Tran</strong>
                        <div><small>Role: Worker</small></div>
                    </div>
                    <div><small>Assigned: South</small></div>
                </div>
            </div>
        </section>
    </div>
</div>
