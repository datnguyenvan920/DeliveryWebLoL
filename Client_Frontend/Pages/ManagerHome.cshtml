  overflow: auto;
  white-space: pre-wrap;
  word-break: break-word;
}
</style>
}

<div class="dw-page">

    <!-- ── Page Header ── -->
    <div class="dw-page-header">
        <div class="dw-page-title">Operations Overview</div>
        <div class="dw-page-subtitle">Manage warehouses and delivery affiliates in real-time</div>
    </div>

    <!-- ── KPI strip ── -->
    <div class="dw-kpi-row">
        <div class="dw-kpi">
            <div class="dw-kpi-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            </div>
            <div class="dw-kpi-value">@(Model.Warehouses?.Items?.Count ?? 0)</div>
            <div class="dw-kpi-label">Warehouses</div>
        </div>
        <div class="dw-kpi">
            <div class="dw-kpi-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <div class="dw-kpi-value">@(Model.Deliverers?.Items?.Count ?? 0)</div>
            <div class="dw-kpi-label">Deliverers</div>
        </div>
        <div class="dw-kpi">
            <div class="dw-kpi-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            </div>
            <div class="dw-kpi-value">—</div>
            <div class="dw-kpi-label">Active Orders</div>
        </div>
        <div class="dw-kpi">
            <div class="dw-kpi-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            </div>
            <div class="dw-kpi-value">—</div>
            <div class="dw-kpi-label">Deliveries Today</div>
        </div>
    </div>

    <!-- ── Two-column panels ── -->
    <div class="dw-grid">

        <!-- ═══ WAREHOUSES ═══ -->
        <div class="dw-panel">
            <div class="dw-panel-bar">
                <div class="dw-panel-bar-left">
                    <div class="dw-panel-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
                        </svg>
                    </div>
                    <div>
                        <div class="dw-panel-title">Warehouses</div>
                        <div class="dw-panel-count">
                            @if (Model.Warehouses?.Items != null)
                            {<span>@Model.Warehouses.Items.Count location@(Model.Warehouses.Items.Count == 1 ? "" : "s")</span>}
                            else
                            {<span>Loading…</span>}
                        </div>
                    </div>
                </div>
                <button class="dw-btn-add" id="dwOpenWarehouse" aria-label="Add warehouse">
                    <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    Add
                </button>
            </div>

            <div class="dw-panel-body">
                @if (Model.Warehouses?.Items == null || Model.Warehouses.Items.Count == 0)
                {
                    <div class="dw-empty">
