@section Scripts {
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
<script>
(function () {
  'use strict';

  /* ── Report UI ────────────────────────────────────────── */
  var reportEl = document.getElementById('dwReport');
  var badgeEl = document.getElementById('dwReportBadge');
  var msgEl = document.getElementById('dwReportMsg');
  var metaEl = document.getElementById('dwReportMeta');
  var detailsEl = document.getElementById('dwReportDetails');
  var closeBtn = document.getElementById('dwReportClose');
  var hideTimer = null;

  function safePretty(obj) {
    try { return JSON.stringify(obj, null, 2); } catch { return String(obj ?? ''); }
  }

  function showReport(opts) {
    if (!reportEl) return;
    if (hideTimer) { clearTimeout(hideTimer); hideTimer = null; }

    var ok = !!opts.ok;
    var title = opts.title || 'Action';
    var status = opts.status || '';
    var message = opts.message || (ok ? 'Success' : 'Failed');
    var details = opts.details ?? '';

    badgeEl.classList.remove('dw-ok', 'dw-err');
    badgeEl.textContent = ok ? 'SUCCESS' : 'ERROR';
    badgeEl.classList.add(ok ? 'dw-ok' : 'dw-err');

    msgEl.textContent = title + ' — ' + message;
    metaEl.textContent = status ? ('HTTP ' + status) : '';

    if (typeof details === 'object') {
      detailsEl.textContent = safePretty(details);
    } else {
      detailsEl.textContent = String(details || '');
    }

    reportEl.classList.add('dw-show');

    // auto-hide after 9s on success; keep errors visible
    if (ok) {
      hideTimer = setTimeout(function () {
        reportEl.classList.remove('dw-show');
      }, 11000);
    }
  }

  if (closeBtn) {
    closeBtn.addEventListener('click', function () {
      if (hideTimer) { clearTimeout(hideTimer); hideTimer = null; }
      reportEl.classList.remove('dw-show');
    });
  }

  /* ── Helpers ──────────────────────────────────────────── */
  function openDwModal(id) {
    var el = document.getElementById(id);
    if (el) { el.classList.add('dw-open'); el.querySelector('.dw-input')?.focus(); }
  }
  function closeDwModal(id) {
    var el = document.getElementById(id);
    if (el) {
      el.classList.remove('dw-open');
      el.querySelectorAll('.dw-input').forEach(function(i){ i.value = ''; });
      el.querySelectorAll('.dw-alert').forEach(function(a){ a.classList.remove('dw-show'); a.textContent = ''; });
      el.querySelectorAll('.dw-btn-submit').forEach(function(b){ b.classList.remove('dw-loading'); });
    }
  }

  /* Click-outside & Escape to close */
  document.querySelectorAll('.dw-modal-wrap').forEach(function(wrap) {
    wrap.addEventListener('click', function(e) { if (e.target === wrap) closeDwModal(wrap.id); });
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      document.querySelectorAll('.dw-modal-wrap.dw-open').forEach(function(m) { closeDwModal(m.id); });
      if (reportEl?.classList.contains('dw-show')) reportEl.classList.remove('dw-show');
    }
  });

  /* ── Antiforgery token (required for Razor Page POST handlers) ── */
  function getAntiforgeryToken() {
    var el = document.querySelector('input[name="__RequestVerificationToken"]');
    return el ? el.value : '';
  }

  /* ── Generic BFF form post → Razor Page handler ── */
  async function postToHandler(handler, fields, errEl, btn, successModalId, reportTitle) {
    errEl.classList.remove('dw-show');
    btn.classList.add('dw-loading');

    var fd = new FormData();
    fd.append('__RequestVerificationToken', getAntiforgeryToken());
    Object.entries(fields).forEach(function(kv) { if (kv[1] !== null && kv[1] !== '') fd.append(kv[0], kv[1]); });

    try {
      var res = await fetch('?handler=' + handler, { method: 'POST', body: fd });
      var json = await res.json().catch(function() { return null; });

      if (!res.ok) {
        var msg = (json && json.message) ? json.message : ('Error ' + res.status);
        errEl.textContent = msg;
        errEl.classList.add('dw-show');
        btn.classList.remove('dw-loading');

        showReport({
          ok: false,
          title: reportTitle || handler,
          status: res.status,
          message: msg,
          details: json && json.details ? json.details : (json || 'No response body')
        });
        return;
      }

      closeDwModal(successModalId);
      btn.classList.remove('dw-loading');

      showReport({
        ok: true,
        title: reportTitle || handler,
        status: res.status,
        message: (json && json.message) ? json.message : 'OK',
        details: json && (json.details ?? json)
      });

      // Refresh data after a short delay so user can see the report
      setTimeout(function(){ location.reload(); }, 600);
    } catch (err) {
      errEl.textContent = 'Network error — ' + err.message;
      errEl.classList.add('dw-show');
      btn.classList.remove('dw-loading');

      showReport({
        ok: false,
        title: reportTitle || handler,
        message: 'Network error',
        details: err && err.stack ? err.stack : String(err)
      });
    }
  }

  /* ── Warehouse Modal ──────────────────────────────────── */
  document.getElementById('dwOpenWarehouse').addEventListener('click', function() { openDwModal('dwWarehouseModal'); });
  document.getElementById('dwCloseWarehouse').addEventListener('click', function() { closeDwModal('dwWarehouseModal'); });
  document.getElementById('dwCancelWarehouse').addEventListener('click', function() { closeDwModal('dwWarehouseModal'); });

  document.getElementById('dwSubmitWarehouse').addEventListener('click', function() {
    var name = document.getElementById('dwWhName').value.trim();
    var addr = document.getElementById('dwWhAddress').value.trim();
    var errEl = document.getElementById('dwWhError');

    if (!name || !addr) {
      errEl.textContent = 'Warehouse Name and Address are required.';
      errEl.classList.add('dw-show');
      return;
    }

    postToHandler('AddWarehouse', {
      name:      name,
      address:   addr,
      latitude:  document.getElementById('dwWhLat').value.trim(),
      longitude: document.getElementById('dwWhLng').value.trim()
    }, errEl, this, 'dwWarehouseModal', 'Add Warehouse');
  });

  /* ── Affiliate Modal ──────────────────────────────────── */
  document.getElementById('dwOpenAffiliate').addEventListener('click', function() { openDwModal('dwAffiliateModal'); });
  document.getElementById('dwCloseAffiliate').addEventListener('click', function() { closeDwModal('dwAffiliateModal'); });
  document.getElementById('dwCancelAffiliate').addEventListener('click', function() { closeDwModal('dwAffiliateModal'); });

  document.getElementById('dwSubmitAffiliate').addEventListener('click', function() {
    var warehouseId = document.getElementById('dwAffWarehouseSelect').value;
    var errEl = document.getElementById('dwAffError');

    if (!warehouseId) {
      errEl.textContent = 'Warehouse is required.';
      errEl.classList.add('dw-show');
      return;
    }

    postToHandler('AddDeliverer', {
      warehouseLocationId:        warehouseId,
      affiliatePrimaryLocationId: document.getElementById('dwAffPrimary').value.trim()
    }, errEl, this, 'dwAffiliateModal', 'Add Affiliate');
  });

  /* ── Map and geocoding for Warehouse modal ─────────────── */
  var whMap = null;
  var whMarker = null;
  var geocodeTimer = null;

  function setLatLngInputs(latlng) {
    var lat = +latlng.lat;
    var lng = +latlng.lng;
    document.getElementById('dwWhLat').value = lat.toFixed(6);
    document.getElementById('dwWhLng').value = lng.toFixed(6);
  }

  async function reverseGeocode(latlng) {
    // Debounce requests
    if (geocodeTimer) window.clearTimeout(geocodeTimer);
    geocodeTimer = window.setTimeout(async function () {
      try {
        var url = 'https://nominatim.openstreetmap.org/reverse?format=jsonv2&lat=' + encodeURIComponent(latlng.lat) + '&lon=' + encodeURIComponent(latlng.lng);
        var res = await fetch(url, {
          headers: {
            // Nominatim usage policy encourages identifying the app
            'Accept': 'application/json'
          }
        });
        if (!res.ok) return;
        var json = await res.json();
        if (json && json.display_name) {
          var addrEl = document.getElementById('dwWhAddress');
          // Only overwrite if user hasn't manually typed something different
          if (!addrEl.dataset.userEdited || addrEl.dataset.userEdited !== 'true') {
            addrEl.value = json.display_name;
          }
        }
      } catch {
        // ignore
      }
    }, 450);
  }

  function ensureWarehouseMap() {
    if (whMap) return;

    var mapEl = document.getElementById('dwWhMap');
    if (!mapEl) return;

    // Default center: Hanoi
    var start = { lat: 21.0285, lng: 105.8542 };

    whMap = L.map(mapEl, { zoomControl: true }).setView([start.lat, start.lng], 13);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      maxZoom: 19,
      attribution: '© OpenStreetMap'
    }).addTo(whMap);

    whMarker = L.marker([start.lat, start.lng], { draggable: true }).addTo(whMap);

    function updateFromLatLng(latlng) {
      setLatLngInputs(latlng);
      reverseGeocode(latlng);
    }

    updateFromLatLng(start);

    whMarker.on('dragend', function () {
      updateFromLatLng(whMarker.getLatLng());
    });

    whMap.on('click', function (e) {
      whMarker.setLatLng(e.latlng);
      updateFromLatLng(e.latlng);
    });

    // track manual edits to address
    var addrEl = document.getElementById('dwWhAddress');
    addrEl.addEventListener('input', function () {
      addrEl.dataset.userEdited = 'true';
    });
  }

  // Hook into modal open so Leaflet can properly size itself
  var btnOpen = document.getElementById('dwOpenWarehouse');
  if (btnOpen) {
    btnOpen.addEventListener('click', function () {
      // modal open is handled by existing code; we just init map after it opens
      window.setTimeout(function () {
        ensureWarehouseMap();
        if (whMap) { whMap.invalidateSize(); }
        // reset address override on every open
        var addrEl = document.getElementById('dwWhAddress');
        if (addrEl) addrEl.dataset.userEdited = 'false';
      }, 120);
    });
  }

})();
</script>
}
