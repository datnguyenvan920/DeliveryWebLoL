                    </div>
                    <div>
                        <div class="dw-panel-title">Deliverers</div>
                        <div class="dw-panel-count">
                            @if (Model.Deliverers?.Items != null)
                            {<span>@Model.Deliverers.Items.Count affiliate@(Model.Deliverers.Items.Count == 1 ? "" : "s")</span>}
                            else
                            {<span>Loading…</span>}
                        </div>
                    </div>
                </div>
                <button class="dw-btn-add" id="dwOpenAffiliate" aria-label="Add affiliate">
                    <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    Add
                </button>
            </div>

            <div class="dw-panel-body">
                @if (Model.Deliverers?.Items == null || Model.Deliverers.Items.Count == 0)
                {
                    <div class="dw-empty">
                        <svg xmlns="http://www.w3.org/2000/svg" width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                        No deliverers found
