@page
@model Client_Frontend.Pages.ManagerHomeModel
@{
    ViewData["Title"] = "Overview — Manager";
    Layout = "_ManagerLayout";
}

@section Head {
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@300;400;500;600;700&family=Russo+One&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
<style>
/* ═══════════════════════════════════════════════════════════
   DeliveryWebLoL — ManagerHome Design System
   Palette  : #0B0E12 bg · #F5C71B yellow · glassmorphism
   Fonts    : Russo One (headings) + Chakra Petch (body)
   Prefix   : dw- (avoids Bootstrap collision)
   ═══════════════════════════════════════════════════════════ */

/* ── Tokens ─────────────────────────────────────────────── */
:root {
  --dw-bg-base:    #0B0E12;
  --dw-bg-surface: #12161D;
  --dw-bg-raised:  #171C25;
  --dw-bg-border:  #1C222B;
  --dw-bg-hover:   #1e2530;

  --dw-yellow:     #F5C71B;
  --dw-yellow-dim: rgba(245,199,27,0.13);
  --dw-yellow-glow: 0 0 18px rgba(245,199,27,0.5), 0 0 36px rgba(245,199,27,0.2);

  --dw-red:        #FF4D6A;
  --dw-green:      #22c55e;
  --dw-blue:       #3B82F6;

  --dw-text:       #FFFFFF;
  --dw-muted:      rgba(255,255,255,0.55);
  --dw-subtle:     rgba(255,255,255,0.28);

  --dw-t:          200ms ease;
  --dw-t-slow:     350ms cubic-bezier(0.22,1,0.36,1);
  --dw-r:          10px;
  --dw-r-lg:       14px;
}

/* ── Body override ──────────────────────────────────────── */
body.manager-shell {
  font-family: 'Chakra Petch', sans-serif;
  background: var(--dw-bg-base) !important;
  color: var(--dw-text) !important;
}

/* ── Page wrapper ───────────────────────────────────────── */
.dw-page {
  padding: 28px 28px 48px;
  min-height: calc(100vh - 64px);
}

/* ── Page header ────────────────────────────────────────── */
.dw-page-header { margin-bottom: 28px; }
.dw-page-title {
  font-family: 'Russo One', sans-serif;
  font-size: 22px;
  letter-spacing: 0.025em;
  color: var(--dw-text);
  line-height: 1.2;
}
.dw-page-subtitle {
  font-size: 13px;
  color: var(--dw-muted);
  margin-top: 4px;
}

/* ── KPI stripe ─────────────────────────────────────────── */
.dw-kpi-row {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  gap: 14px;
  margin-bottom: 28px;
}
.dw-kpi {
  background: var(--dw-bg-surface);
  border: 1px solid var(--dw-bg-border);
  border-radius: var(--dw-r-lg);
  padding: 16px 18px;
  position: relative;
  overflow: hidden;
  transition: border-color var(--dw-t), box-shadow var(--dw-t);
  cursor: default;
}
.dw-kpi::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; height: 2px;
  background: linear-gradient(90deg, var(--dw-yellow), transparent);
  opacity: 0.7;
}
.dw-kpi:hover {
  border-color: rgba(245,199,27,0.28);
  box-shadow: 0 4px 20px rgba(0,0,0,0.4);
}
.dw-kpi-icon {
  width: 34px; height: 34px;
  border-radius: 8px;
  background: var(--dw-yellow-dim);
  display: flex; align-items: center; justify-content: center;
  color: var(--dw-yellow);
  margin-bottom: 10px;
  flex-shrink: 0;
}
.dw-kpi-value {
  font-family: 'Russo One', sans-serif;
  font-size: 24px;
  color: var(--dw-text);
  line-height: 1.1;
}
.dw-kpi-label {
  font-size: 11px;
  color: var(--dw-muted);
  margin-top: 3px;
  text-transform: uppercase;
  letter-spacing: 0.07em;
}

/* ── Two-column panel grid ──────────────────────────────── */
.dw-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 22px;
}
@@media (max-width: 900px) {
  .dw-grid { grid-template-columns: 1fr; }
  .dw-page { padding: 18px; }
  .dw-kpi-row { grid-template-columns: 1fr 1fr; }
}

/* ── Panel card ─────────────────────────────────────────── */
.dw-panel {
  background: var(--dw-bg-surface);
  border: 1px solid var(--dw-bg-border);
  border-radius: var(--dw-r-lg);
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* ── Panel top bar ──────────────────────────────────────── */
.dw-panel-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 20px 14px;
  border-bottom: 1px solid var(--dw-bg-border);
  flex-shrink: 0;
}
.dw-panel-bar-left {
  display: flex;
  align-items: center;
  gap: 12px;
}
.dw-panel-icon {
  width: 36px; height: 36px;
  border-radius: 9px;
  background: var(--dw-yellow-dim);
  border: 1px solid rgba(245,199,27,0.18);
  display: flex; align-items: center; justify-content: center;
  color: var(--dw-yellow);
  flex-shrink: 0;
}
.dw-panel-title {
  font-family: 'Russo One', sans-serif;
  font-size: 14px;
  color: var(--dw-text);
  letter-spacing: 0.02em;
}
.dw-panel-count {
  font-size: 11px;
  color: var(--dw-subtle);
  margin-top: 2px;
}

/* Add button */
.dw-btn-add {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: var(--dw-yellow);
  color: #111;
  font-family: 'Russo One', sans-serif;
  font-size: 11px;
  letter-spacing: 0.05em;
  padding: 7px 13px;
  border-radius: 8px;
  border: none;
  cursor: pointer;
  transition: filter var(--dw-t), box-shadow var(--dw-t);
  box-shadow: 0 2px 10px rgba(245,199,27,0.2);
  white-space: nowrap;
  text-transform: uppercase;
}
.dw-btn-add:hover {
  filter: brightness(1.12);
  box-shadow: 0 4px 18px rgba(245,199,27,0.4);
}

/* ── Panel body / scroll area ───────────────────────────── */
.dw-panel-body {
  flex: 1;
  overflow-y: auto;
  max-height: 380px;
}
.dw-panel-body::-webkit-scrollbar { width: 4px; }
.dw-panel-body::-webkit-scrollbar-track { background: transparent; }
.dw-panel-body::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.08); border-radius: 4px; }

/* ── Empty state ────────────────────────────────────────── */
.dw-empty {
  padding: 40px 20px;
  text-align: center;
  color: var(--dw-subtle);
  font-size: 13px;
}
.dw-empty svg {
  display: block;
  margin: 0 auto 10px;
  opacity: 0.2;
}

/* ── Row item ───────────────────────────────────────────── */
.dw-item {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 13px 20px;
  border-bottom: 1px solid rgba(255,255,255,0.035);
  transition: background var(--dw-t);
  cursor: default;
}
.dw-item:last-child { border-bottom: none; }
.dw-item:hover { background: var(--dw-bg-hover); }

.dw-avatar {
  width: 38px; height: 38px;
  border-radius: 10px;
  background: var(--dw-bg-raised);
  border: 1px solid var(--dw-bg-border);
  display: flex; align-items: center; justify-content: center;
  color: var(--dw-yellow);
  font-family: 'Russo One', sans-serif;
  font-size: 13px;
  flex-shrink: 0;
}

.dw-item-info { flex: 1; min-width: 0; }
.dw-item-name {
  font-weight: 700;
  font-size: 13.5px;
  color: var(--dw-text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.dw-item-meta {
  font-size: 11.5px;
  color: var(--dw-muted);
  margin-top: 2px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.dw-tag {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.07em;
  padding: 3px 9px;
  border-radius: 20px;
  background: var(--dw-yellow-dim);
  color: var(--dw-yellow);
  border: 1px solid rgba(245,199,27,0.22);
  white-space: nowrap;
  flex-shrink: 0;
  font-family: 'Chakra Petch', monospace;
  text-transform: uppercase;
}

/* ── JWT note banner ────────────────────────────────────── */
.dw-note {
  margin-top: 20px;
  display: flex;
  align-items: flex-start;
  gap: 10px;
  background: rgba(245,199,27,0.04);
  border: 1px solid rgba(245,199,27,0.1);
  border-radius: 10px;
  padding: 12px 16px;
  font-size: 12px;
  color: var(--dw-subtle);
  line-height: 1.6;
}
.dw-note svg { color: var(--dw-yellow); margin-top: 1px; flex-shrink: 0; }

/* ═══════════════════════════════════════════════════════════
   DARK MODAL SYSTEM  (dw- prefix — Bootstrap-safe)
   ═══════════════════════════════════════════════════════════ */

.dw-modal-wrap {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1060;
  padding: 16px;
  /* Hidden by default */
  opacity: 0;
  pointer-events: none;
  transition: opacity var(--dw-t-slow);
}
.dw-modal-wrap::before {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.78);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
}
.dw-modal-wrap.dw-open {
  opacity: 1;
  pointer-events: all;
}

.dw-modal {
  position: relative;
  z-index: 1;
  background: var(--dw-bg-surface);
  border: 1px solid rgba(245,199,27,0.28);
  border-radius: var(--dw-r-lg);
  padding: 28px 28px 24px;
  width: 100%;
  max-width: 480px;
  box-shadow:
    0 0 0 1px rgba(245,199,27,0.06) inset,
    0 0 40px rgba(245,199,27,0.07),
    0 24px 64px rgba(0,0,0,0.75);
  transform: translateY(18px) scale(0.98);
  transition: transform var(--dw-t-slow);
  /* top shimmer */
  overflow: hidden;
}
.dw-modal::before {
  content: '';
  position: absolute;
  top: 0; left: 10%; right: 10%; height: 1px;
  background: linear-gradient(90deg, transparent, rgba(245,199,27,0.6), transparent);
}
.dw-modal-wrap.dw-open .dw-modal {
  transform: translateY(0) scale(1);
}

/* Modal top row */
.dw-modal-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22px;
}
.dw-modal-heading {
  font-family: 'Russo One', sans-serif;
  font-size: 17px;
  color: var(--dw-text);
  letter-spacing: 0.02em;
  display: flex;
  align-items: center;
  gap: 10px;
}
.dw-modal-heading-icon {
  width: 32px; height: 32px;
  border-radius: 8px;
  background: var(--dw-yellow-dim);
  border: 1px solid rgba(245,199,27,0.2);
  display: flex; align-items: center; justify-content: center;
  color: var(--dw-yellow);
}
.dw-modal-x {
  width: 30px; height: 30px;
  border-radius: 7px;
  background: var(--dw-bg-raised);
  border: 1px solid var(--dw-bg-border);
  color: var(--dw-muted);
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  transition: color var(--dw-t), border-color var(--dw-t), background var(--dw-t);
  flex-shrink: 0;
}
.dw-modal-x:hover {
  color: var(--dw-red);
  border-color: rgba(255,77,106,0.3);
  background: rgba(255,77,106,0.07);
}

/* Field */
.dw-field { margin-bottom: 14px; }
.dw-field:last-of-type { margin-bottom: 0; }

.dw-label {
  display: block;
  font-size: 10.5px;
  font-weight: 700;
  letter-spacing: 0.10em;
  text-transform: uppercase;
  color: var(--dw-muted);
  margin-bottom: 6px;
}
.dw-label-opt {
  font-weight: 400;
  text-transform: none;
  letter-spacing: 0;
  color: var(--dw-subtle);
  font-size: 10px;
  margin-left: 6px;
}

.dw-input {
  width: 100%;
  background: var(--dw-bg-base) !important;
  border: 1px solid var(--dw-bg-border) !important;
  border-radius: 8px !important;
  color: var(--dw-text) !important;
  padding: 11px 14px !important;
  font-family: 'Chakra Petch', sans-serif !important;
  font-size: 13.5px !important;
  outline: none !important;
  transition: border-color var(--dw-t), box-shadow var(--dw-t) !important;
  -webkit-appearance: none;
}
.dw-input:focus {
  border-color: var(--dw-yellow) !important;
  box-shadow: 0 0 0 3px rgba(245,199,27,0.12) !important;
}
.dw-input::placeholder { color: var(--dw-subtle) !important; font-style: italic; }

.dw-input-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

/* Error alert */
.dw-alert {
  display: none;
  background: rgba(255,77,106,0.1);
  border: 1px solid rgba(255,77,106,0.28);
  color: var(--dw-red);
  border-radius: 8px;
  padding: 10px 14px;
  font-size: 12px;
  margin-bottom: 16px;
  line-height: 1.5;
}
.dw-alert.dw-show { display: block; }

/* Footer */
.dw-modal-foot {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10px;
  margin-top: 22px;
  padding-top: 18px;
  border-top: 1px solid var(--dw-bg-border);
}
.dw-btn-cancel {
  padding: 9px 18px;
  border-radius: 8px;
  background: var(--dw-bg-raised);
  border: 1px solid var(--dw-bg-border);
  color: var(--dw-muted);
  font-family: 'Chakra Petch', sans-serif;
  font-size: 13px;
  cursor: pointer;
  transition: color var(--dw-t), border-color var(--dw-t);
}
.dw-btn-cancel:hover { color: var(--dw-text); border-color: rgba(255,255,255,0.18); }

.dw-btn-submit {
  padding: 9px 22px;
  border-radius: 8px;
  background: var(--dw-yellow);
  color: #111;
  font-family: 'Russo One', sans-serif;
  font-size: 12px;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  border: none;
  cursor: pointer;
  transition: filter var(--dw-t), box-shadow var(--dw-t);
  box-shadow: 0 2px 12px rgba(245,199,27,0.25);
  position: relative;
  overflow: hidden;
}
.dw-btn-submit::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, transparent 30%, rgba(255,255,255,0.18) 50%, transparent 70%);
  transform: translateX(-100%);
  transition: transform 0.4s ease;
}
.dw-btn-submit:hover {
  filter: brightness(1.12);
  box-shadow: 0 4px 20px rgba(245,199,27,0.4);
}
.dw-btn-submit:hover::before { transform: translateX(100%); }

/* ── Spinner on submit ──────────────────────────────────── */
.dw-btn-submit.dw-loading { pointer-events: none; opacity: 0.75; }
.dw-btn-submit.dw-loading::after {
  content: '';
  display: inline-block;
  width: 12px; height: 12px;
  border: 2px solid rgba(0,0,0,0.3);
  border-top-color: #111;
  border-radius: 50%;
  animation: dwSpin 0.7s linear infinite;
  margin-left: 8px;
  vertical-align: middle;
}
@@keyframes dwSpin { to { transform: rotate(360deg); } }

/* ── Reduced motion ─────────────────────────────────────── */
@@media (prefers-reduced-motion: reduce) {
  .dw-modal-wrap, .dw-modal { transition: none !important; }
  .dw-btn-submit::before { display: none; }
}

/* ── Action Report (API response viewer) ────────────────── */
.dw-report {
  position: fixed;
  right: 18px;
  bottom: 18px;
  width: min(520px, calc(100vw - 36px));
  z-index: 1070;
  background: rgba(18,22,29,0.96);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 14px;
  box-shadow: 0 24px 64px rgba(0,0,0,0.7);
  overflow: hidden;
  opacity: 0;
  transform: translateY(12px);
  pointer-events: none;
  transition: opacity var(--dw-t-slow), transform var(--dw-t-slow);
}
.dw-report.dw-show { opacity: 1; transform: translateY(0); pointer-events: all; }

.dw-report-bar {
  display:flex; align-items:center; justify-content:space-between;
  padding: 12px 14px;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}
.dw-report-title {
  display:flex; align-items:center; gap:10px;
  font-family: 'Russo One', sans-serif;
  font-size: 12.5px;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--dw-text);
}
.dw-report-badge {
  font-family: 'Chakra Petch', monospace;
  font-size: 10.5px;
  letter-spacing: 0.05em;
  padding: 3px 10px;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,0.08);
  color: var(--dw-muted);
}
.dw-report-badge.dw-ok { color: var(--dw-green); border-color: rgba(34,197,94,0.25); background: rgba(34,197,94,0.08); }
.dw-report-badge.dw-err { color: var(--dw-red); border-color: rgba(255,77,106,0.25); background: rgba(255,77,106,0.08); }

.dw-report-x {
  width: 30px; height: 30px;
  border-radius: 9px;
  background: var(--dw-bg-raised);
  border: 1px solid rgba(255,255,255,0.08);
  color: var(--dw-muted);
  display:flex; align-items:center; justify-content:center;
  cursor:pointer;
}
.dw-report-x:hover { color: var(--dw-red); border-color: rgba(255,77,106,0.3); background: rgba(255,77,106,0.07); }

.dw-report-body { padding: 12px 14px 14px; }
.dw-report-msg { color: var(--dw-text); font-weight: 700; font-size: 13px; margin-bottom: 8px; }
.dw-report-meta { color: var(--dw-muted); font-size: 11.5px; margin-bottom: 10px; }
.dw-report-pre {
  margin: 0;
  padding: 12px;
  border-radius: 12px;
  background: #0B0E12;
  border: 1px solid rgba(255,255,255,0.08);
  color: rgba(255,255,255,0.78);
  font-size: 11.5px;
  line-height: 1.55;
  max-height: 220px;
  overflow: auto;
  white-space: pre-wrap;
  word-break: break-word;
}

.dw-map {
  height: 260px;
  border-radius: 10px;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,0.08);
  background: #0B0E12;
}
.dw-map-help {
  font-size: 11.5px;
  color: rgba(255,255,255,0.45);
  margin-top: 8px;
  line-height: 1.35;
}
.dw-coord-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

/* ── Action Report (API response viewer) ────────────────── */
