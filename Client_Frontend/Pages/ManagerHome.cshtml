@page
@model Client_Frontend.Pages.ManagerHomeModel
@{
    ViewData["Title"] = "Manager Home";
    Layout = "_ManagerLayout";
}

<div class="manager-page">
    <div class="app-grid">
        <section class="card">
            <h3>Warehouses</h3>

            @if (Model.Warehouses?.Items == null || Model.Warehouses.Items.Count == 0)
            {
                <div class="list-item"><small>No warehouses found.</small></div>
            }
            else
            {
                @foreach (var w in Model.Warehouses.Items)
                {
                    <div class="list-item">
                        <div style="display:flex;justify-content:space-between;align-items:center">
                            <div>
                                <strong>@w.Name</strong>
                                <div><small>Address: @w.Address</small></div>
                            </div>
                            <div><small>ID: @w.LocationID</small></div>
                        </div>
                    </div>
                }
            }
        </section>

        <section class="card">
            <h3>Deliverers</h3>

            @if (Model.Deliverers?.Items == null || Model.Deliverers.Items.Count == 0)
            {
                <div class="list-item"><small>No deliverers found.</small></div>
            }
            else
            {
                @foreach (var d in Model.Deliverers.Items)
                {
                    <div class="list-item">
                        <div style="display:flex;justify-content:space-between;align-items:center">
                            <div>
                                <strong>@d.Username</strong>
                                <div><small>@(d.Email ?? d.ContactPhone ?? "")</small></div>
                            </div>
                            <div><small>Affiliation: @d.AffiliationId</small></div>
                        </div>
                    </div>
                }
            }
        </section>
    </div>

    <div style="margin-top:12px; color: rgba(255,255,255,0.6)">
        <small>
            Note: these endpoints are protected by JWT ([Authorize]). If the lists are empty due to 401/403,
            you need to attach the access token (Bearer) in ManagerHomeModel.
        </small>
    </div>
</div>
