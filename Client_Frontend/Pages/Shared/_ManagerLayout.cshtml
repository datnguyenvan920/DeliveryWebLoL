@*
    _ManagerLayout.cshtml
    Full-screen shell: top navbar + left sidebar.
    Matches the ManagerDashboard dark gaming aesthetic (dashboard.css).
    Sidebar uses asp-page links — active state is determined by current page.
*@
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@{
    var username  = HttpContextAccessor.HttpContext?.Session.GetString("username") ?? "Manager";
    var initial   = username.Length > 0 ? username[0].ToString().ToUpper() : "M";
    var curPage   = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="DeliveryWebLoL Manager Portal" />
    <title>@ViewData["Title"] — DeliveryWebLoL</title>
    <link rel="icon" href="~/favicon.ico" />

    @* Design system *@
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@300;400;500;600;700&family=Russo+One&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/auth.css"       asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard.css"  asp-append-version="true" />

    @* Expose API base URL for client-side scripts *@
    <meta name="api-base" content="@(Configuration["ApiBaseUrl"] ?? "")" />

    <style>
        /* ── Shell base: use dashboard tokens ────────────────────── */
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body.ml-shell {
            font-family: 'Chakra Petch', sans-serif;
            background: #0B0E12;
            color: #fff;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            overflow-x: hidden;
        }

        /* ── Navbar ──────────────────────────────────────────────── */
        .ml-navbar {
            position: fixed;
            top: 0; left: 0; right: 0;
            height: 60px;
            background: #12161D;
            border-bottom: 1px solid #1C222B;
            display: flex;
            align-items: center;
            padding: 0 20px;
            gap: 16px;
            z-index: 200;
        }

        /* Hamburger (mobile) */
        .ml-hamburger {
            display: none;
            width: 36px; height: 36px;
            align-items: center; justify-content: center;
            border-radius: 8px;
            background: #171C25;
            border: 1px solid #1C222B;
            color: rgba(255,255,255,0.55);
            cursor: pointer;
            transition: color 200ms ease, border-color 200ms ease;
            flex-shrink: 0;
        }
        .ml-hamburger:hover { color: #F5C71B; border-color: rgba(245,199,27,0.35); }

        /* Brand */
        .ml-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            min-width: 220px;
            text-decoration: none;
        }
        .ml-brand-mark {
            width: 36px; height: 36px;
            background: #F5C71B;
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            font-family: 'Russo One', sans-serif;
            font-size: 13px: color: #111; font-weight: 900;
            box-shadow: 0 0 12px rgba(245,199,27,0.4);
            flex-shrink: 0;
        }
        .ml-brand-name {
            font-family: 'Russo One', sans-serif;
            font-size: 14px;
            color: #fff;
            letter-spacing: 0.03em;
            line-height: 1.1;
        }
        .ml-brand-sub {
            font-size: 10px;
            color: rgba(255,255,255,0.4);
            letter-spacing: 0.04em;
            text-transform: uppercase;
        }

        /* Right cluster */
        .ml-navbar-right {
            margin-left: auto;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .ml-role-badge {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            padding: 3px 10px;
            border-radius: 20px;
            background: #F5C71B;
            color: #111;
        }
        .ml-icon-btn {
            width: 34px; height: 34px;
            border-radius: 8px;
            background: #171C25;
            border: 1px solid #1C222B;
            color: rgba(255,255,255,0.55);
            display: flex; align-items: center; justify-content: center;
            cursor: pointer;
            text-decoration: none;
            transition: color 200ms ease, border-color 200ms ease;
        }
        .ml-icon-btn:hover { color: #F5C71B; border-color: rgba(245,199,27,0.35); }

        /* Avatar + dropdown */
        .ml-avatar-wrap { position: relative; }
        .ml-avatar {
            width: 34px; height: 34px;
            border-radius: 50%;
            background: linear-gradient(135deg, #F5C71B, #e6a800);
            display: flex; align-items: center; justify-content: center;
            font-family: 'Russo One', sans-serif;
            font-size: 13px; color: #111;
            cursor: pointer;
            box-shadow: 0 0 10px rgba(245,199,27,0.3);
            border: none;
            transition: box-shadow 200ms ease;
        }
        .ml-avatar:hover { box-shadow: 0 0 18px rgba(245,199,27,0.55); }

        /* User dropdown */
        .ml-dropdown {
            position: absolute;
            top: calc(100% + 10px);
            right: 0;
            min-width: 200px;
            background: #12161D;
            border: 1px solid #1C222B;
            border-radius: 12px;
            padding: 6px;
            box-shadow: 0 16px 50px rgba(0,0,0,0.65);
            opacity: 0;
            pointer-events: none;
            transform: translateY(6px);
            transition: opacity 200ms ease, transform 200ms ease;
            z-index: 300;
        }
        .ml-avatar-wrap.open .ml-dropdown {
            opacity: 1;
            pointer-events: all;
            transform: translateY(0);
        }
        .ml-dropdown-header {
            padding: 10px 12px 8px;
            border-bottom: 1px solid #1C222B;
            margin-bottom: 4px;
        }
        .ml-dropdown-name {
            font-weight: 700;
            font-size: 13px;
            color: #fff;
        }
        .ml-dropdown-sub {
            font-size: 11px;
            color: rgba(255,255,255,0.4);
            margin-top: 1px;
        }
        .ml-dd-item {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 8px 12px;
            border-radius: 8px;
            font-size: 13px;
            color: rgba(255,255,255,0.7);
            text-decoration: none;
            cursor: pointer;
            transition: background 150ms ease, color 150ms ease;
            background: none;
            border: none;
            width: 100%;
            text-align: left;
        }
        .ml-dd-item:hover { background: #1e2530; color: #fff; }
        .ml-dd-item.logout:hover { background: rgba(255,77,106,0.1); color: #FF4D6A; }
        .ml-dd-divider {
            height: 1px;
            background: #1C222B;
            margin: 4px 6px;
        }

        /* ── Sidebar ─────────────────────────────────────────────── */
        .ml-sidebar {
            position: fixed;
            top: 60px; left: 0; bottom: 0;
            width: 230px;
            background: #12161D;
            border-right: 1px solid #1C222B;
            padding: 20px 10px;
            display: flex;
            flex-direction: column;
            gap: 3px;
            overflow-y: auto;
            z-index: 100;
            transition: transform 350ms cubic-bezier(0.22,1,0.36,1);
        }
        .ml-sidebar::-webkit-scrollbar { width: 3px; }
        .ml-sidebar::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.06); border-radius: 3px; }

        .ml-section-label {
            font-size: 10px;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: rgba(255,255,255,0.28);
            padding: 14px 10px 6px;
        }

        .ml-nav-link {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 9px 12px;
            border-radius: 8px;
            color: rgba(255,255,255,0.55);
            font-size: 13px;
            font-weight: 500;
            text-decoration: none;
            cursor: pointer;
            transition: background 180ms ease, color 180ms ease, border-left-color 180ms ease;
            border-left: 2px solid transparent;
            position: relative;
        }
        .ml-nav-link svg { flex-shrink: 0; opacity: 0.8; }
        .ml-nav-link:hover {
            background: #1e2530;
            color: #fff;
        }
        .ml-nav-link.active {
            background: rgba(245,199,27,0.12);
            color: #F5C71B;
            border-left-color: #F5C71B;
            font-weight: 700;
        }
        .ml-nav-link.active svg { opacity: 1; }
        .ml-nav-link.disabled {
            opacity: 0.35;
            pointer-events: none;
            cursor: default;
        }

        .ml-nav-badge {
            margin-left: auto;
            font-size: 10px;
            background: #F5C71B;
            color: #111;
            padding: 2px 7px;
            border-radius: 10px;
            font-weight: 700;
        }

        /* ── Main content area ───────────────────────────────────── */
        .ml-main {
            margin-left: 230px;
            padding-top: 60px;
            flex: 1;
            min-height: 100vh;
            background: linear-gradient(180deg, #0B0E12 0%, #0d1118 100%);
        }

        /* ── Mobile ──────────────────────────────────────────────── */
        @@media (max-width: 768px) {
            .ml-hamburger { display: flex; }
            .ml-brand { min-width: unset; }
            .ml-sidebar { transform: translateX(-230px); }
            .ml-sidebar.open { transform: translateX(0); }
            .ml-main { margin-left: 0; }
            .ml-role-badge { display: none; }
        }
    </style>

    @await RenderSectionAsync("Head", required: false)
</head>
<body class="ml-shell">

<!-- ═══════════════════════════════════════════════════════
     TOP NAVBAR
     ═══════════════════════════════════════════════════════ -->
<nav class="ml-navbar" role="navigation" aria-label="Main navigation">

    <!-- Hamburger (mobile only) -->
    <button class="ml-hamburger" id="mlHamburger" aria-label="Toggle sidebar" aria-expanded="false">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
    </button>

    <!-- Brand -->
    <a class="ml-brand" asp-page="/ManagerHome">
        <div class="ml-brand-mark">DW</div>
        <div>
            <div class="ml-brand-name">DeliveryWebLoL</div>
            <div class="ml-brand-sub">Manager Portal</div>
        </div>
    </a>

    <!-- Right controls -->
    <div class="ml-navbar-right">
        <span class="ml-role-badge">Manager</span>

        <!-- Notifications (placeholder) -->
        <button class="ml-icon-btn" title="Notifications" aria-label="Notifications">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/>
            </svg>
        </button>

        <!-- Avatar + dropdown -->
        <div class="ml-avatar-wrap" id="mlAvatarWrap">
            <button class="ml-avatar" id="mlAvatarBtn" title="@username" aria-haspopup="true" aria-expanded="false">
                @initial
            </button>
            <div class="ml-dropdown" id="mlDropdown" role="menu">
                <div class="ml-dropdown-header">
                    <div class="ml-dropdown-name">@username</div>
                    <div class="ml-dropdown-sub">Manager · Signed in</div>
                </div>
                <a class="ml-dd-item" asp-page="/ManagerHome" role="menuitem">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                    Overview
                </a>
                <a class="ml-dd-item" asp-page="/ManagerDashboard" role="menuitem">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                    Full Dashboard
                </a>
                <div class="ml-dd-divider"></div>
                <form method="post" asp-page="/Logout">
                    <button type="submit" class="ml-dd-item logout" role="menuitem">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                        Sign Out
                    </button>
                </form>
            </div>
        </div>
    </div>
</nav>


<!-- ═══════════════════════════════════════════════════════
     LEFT SIDEBAR
     ═══════════════════════════════════════════════════════ -->
<aside class="ml-sidebar" id="mlSidebar" role="complementary" aria-label="Sidebar navigation">

    <div class="ml-section-label">Overview</div>

    <a class="ml-nav-link @(curPage == "/ManagerHome" ? "active" : "")" asp-page="/ManagerHome">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
            <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
        </svg>
        Operations Overview
    </a>

    <a class="ml-nav-link @(curPage == "/ManagerDashboard" ? "active" : "")" asp-page="/ManagerDashboard">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
        </svg>
        Analytics Dashboard
    </a>

    <div class="ml-section-label">Operations</div>

    <a class="ml-nav-link @(curPage == "/OrderList" ? "active" : "")" asp-page="/OrderList">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="1" y="3" width="15" height="13"/>
            <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
            <circle cx="5.5" cy="18.5" r="2.5"/>
            <circle cx="18.5" cy="18.5" r="2.5"/>
        </svg>
        Orders
    </a>

    <a class="ml-nav-link disabled" href="#" aria-disabled="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
        </svg>
        Inventory
    </a>

    <div class="ml-section-label">Team</div>


    <a class="ml-nav-link @(curPage == "/Affiliates" ? "active" : "")" asp-page="/Affiliates">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="3"/>
            <path d="M19.07 4.93a10 10 0 0 1 0 14.14"/>
            <path d="M4.93 4.93a10 10 0 0 0 0 14.14"/>
        </svg>
        Affiliates
    </a>

    <a class="ml-nav-link @(curPage == "/AffiliateGuids" ? "active" : "")" asp-page="/AffiliateGuids">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
        </svg>
        Affiliate GUIDs
    </a>

    <div class="ml-section-label">Account</div>

    <a class="ml-nav-link disabled" href="#" aria-disabled="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
        </svg>
        Settings
    </a>

    <!-- Sign out at bottom -->
    <div style="margin-top:auto; padding-top:16px; border-top:1px solid #1C222B;">
        <form method="post" asp-page="/Logout">
            <button type="submit" class="ml-nav-link" style="width:100%;color:rgba(255,77,106,0.75);border:none;background:none;cursor:pointer;">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
                </svg>
                Sign Out
            </button>
        </form>
    </div>
</aside>


<!-- ═══════════════════════════════════════════════════════
     MAIN CONTENT
     ═══════════════════════════════════════════════════════ -->
<main class="ml-main" id="mlMain">
    @RenderBody()
</main>


<!-- ── Scripts ─────────────────────────────────────────── -->
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

<script>
    window.__apiBase__ = @System.Text.Json.JsonSerializer.Serialize(Configuration["ApiBaseUrl"] ?? "");

    (function () {
        // ── Avatar dropdown ─────────────────────────────────────
        var avatarWrap = document.getElementById('mlAvatarWrap');
        var avatarBtn  = document.getElementById('mlAvatarBtn');

        avatarBtn.addEventListener('click', function (e) {
            e.stopPropagation();
            var open = avatarWrap.classList.toggle('open');
            avatarBtn.setAttribute('aria-expanded', open);
        });
        document.addEventListener('click', function () {
            avatarWrap.classList.remove('open');
            avatarBtn.setAttribute('aria-expanded', 'false');
        });

        // ── Mobile sidebar toggle ────────────────────────────────
        var hamburger = document.getElementById('mlHamburger');
        var sidebar   = document.getElementById('mlSidebar');

        hamburger.addEventListener('click', function () {
            var open = sidebar.classList.toggle('open');
            hamburger.setAttribute('aria-expanded', open);
        });

        // Close sidebar when clicking main area on mobile
        document.getElementById('mlMain').addEventListener('click', function () {
            if (window.innerWidth <= 768) {
                sidebar.classList.remove('open');
                hamburger.setAttribute('aria-expanded', 'false');
            }
        });
    })();
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
