<!DOCTYPE html>
<html lang="en">
<head>
    @inject Microsoft.Extensions.Configuration.IConfiguration Configuration
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Client_Frontend</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Client_Frontend.styles.css" asp-append-version="true" />

    @* Expose API base as a meta tag for client scripts to pick up *@
    <meta name="api-base" content="@(Configuration["ApiBaseUrl"] ?? "")" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">Client_Frontend</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Privacy">Privacy</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Client_Frontend - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @* Inject API base URL into the page so client-side ajax can target the API project when hosted separately *@
    <script>
        // Serialized to a JS string to ensure it's valid and escaped
        window.__apiBase__ = @System.Text.Json.JsonSerializer.Serialize(Configuration["ApiBaseUrl"] ?? "");

        // Quick validation: warn if api base not provided
        (function() {
            var meta = document.querySelector('meta[name="api-base"]');
            var metaVal = meta ? meta.content : '';
            if (!metaVal || metaVal.trim() === '') {
                console.warn('API base URL (ApiBaseUrl) is not configured in Client_Frontend. Client-side AJAX will fall back to a default. Set ApiBaseUrl in appsettings or supply window.__apiBase__.');
            }
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>