@*
    _AffiliateLayout.cshtml — Shared shell for Affiliate pages.
    Similar to _DriverLayout (no sidebar), with a distinct purple accent.
*@
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@{
    var username = HttpContextAccessor.HttpContext?.Session.GetString("username") ?? "Affiliate";
    var initial  = username.Length > 0 ? username[0].ToString().ToUpper() : "A";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="DeliveryWebLoL Affiliate Portal" />
    <title>@ViewData["Title"] — DeliveryWebLoL</title>
    <link rel="icon" href="~/favicon.ico" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@300;400;500;600;700&family=Russo+One&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/auth.css"      asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />

    <meta name="api-base" content="@(Configuration["ApiBaseUrl"] ?? "")" />

    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body.afl-shell {
            font-family: 'Chakra Petch', sans-serif;
            background: #0B0E12;
            color: #fff;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            overflow-x: hidden;
        }

        .afl-navbar {
            position: fixed; top: 0; left: 0; right: 0; height: 60px;
            background: #12161D; border-bottom: 1px solid #1C222B;
            display: flex; align-items: center; padding: 0 20px; gap: 16px; z-index: 200;
        }

        .afl-brand { display:flex; align-items:center; gap:10px; text-decoration:none; }
        .afl-brand-mark {
            width: 36px; height: 36px; border-radius: 8px;
            background: #8B5CF6;
            display:flex; align-items:center; justify-content:center;
            font-family: 'Russo One', sans-serif;
            font-size: 13px; font-weight: 900;
            color: #fff;
            box-shadow: 0 0 12px rgba(139,92,246,0.4);
            flex-shrink: 0;
        }
        .afl-brand-name { font-family: 'Russo One', sans-serif; font-size: 14px; color:#fff; letter-spacing:0.03em; line-height:1.1; }
        .afl-brand-sub  { font-size: 10px; color: rgba(255,255,255,0.4); letter-spacing:0.04em; text-transform:uppercase; }

        .afl-navbar-right { margin-left:auto; display:flex; align-items:center; gap: 12px; }
        .afl-role-badge {
            font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
            padding: 3px 10px; border-radius: 20px;
            background: #8B5CF6; color: #fff;
        }

        .afl-chip {
            background: #171C25;
            border: 1px solid #1C222B;
            border-radius: 999px;
            padding: 4px 12px;
            font-size: 12px;
            color: rgba(255,255,255,0.55);
        }
        .afl-chip-purple {
            background: rgba(139,92,246,0.14);
            border-color: rgba(139,92,246,0.28);
            color: rgba(167,139,250,0.95);
            font-weight: 800;
        }

        .afl-icon-btn {
            width: 34px; height: 34px;
            border-radius: 8px;
            background: #171C25;
            border: 1px solid #1C222B;
            color: rgba(255,255,255,0.55);
            display:flex; align-items:center; justify-content:center;
            cursor:pointer;
            transition: color 200ms ease, border-color 200ms ease;
            text-decoration:none;
        }
        .afl-icon-btn:hover { color: #8B5CF6; border-color: rgba(139,92,246,0.35); }

        .afl-avatar-wrap { position: relative; }
        .afl-avatar {
            width: 34px; height: 34px; border-radius: 50%;
            background: linear-gradient(135deg, #8B5CF6, #6D28D9);
            display:flex; align-items:center; justify-content:center;
            font-family: 'Russo One', sans-serif;
            font-size: 13px;
            color:#fff;
            cursor:pointer;
            border:none;
            box-shadow: 0 0 10px rgba(139,92,246,0.3);
        }
        .afl-avatar:hover { box-shadow: 0 0 18px rgba(139,92,246,0.55); }

        .afl-dropdown {
            position: absolute;
            top: calc(100% + 10px);
            right: 0;
            min-width: 200px;
            background: #12161D;
            border: 1px solid #1C222B;
            border-radius: 12px;
            padding: 6px;
            box-shadow: 0 16px 50px rgba(0,0,0,0.65);
            opacity: 0;
            pointer-events: none;
            transform: translateY(6px);
            transition: opacity 200ms ease, transform 200ms ease;
            z-index: 300;
        }
        .afl-avatar-wrap.open .afl-dropdown { opacity: 1; pointer-events: all; transform: translateY(0); }
        .afl-dropdown-header { padding: 10px 12px 8px; border-bottom: 1px solid #1C222B; margin-bottom: 4px; }
        .afl-dropdown-name { font-weight: 700; font-size: 13px; color: #fff; }
        .afl-dropdown-sub  { font-size: 11px; color: rgba(255,255,255,0.4); margin-top: 1px; }
        .afl-dd-item {
            display:flex; align-items:center; gap: 8px;
            padding: 8px 12px;
            border-radius: 8px;
            font-size: 13px;
            color: rgba(255,255,255,0.7);
            text-decoration:none;
            cursor:pointer;
            transition: background 150ms ease, color 150ms ease;
            background: none;
            border: none;
            width: 100%;
            text-align:left;
        }
        .afl-dd-item:hover { background: #1e2530; color: #fff; }
        .afl-dd-item.logout:hover { background: rgba(255,77,106,0.1); color: #FF4D6A; }
        .afl-dd-divider { height: 1px; background: #1C222B; margin: 4px 6px; }

        .afl-main {
            padding-top: 60px;
            flex: 1;
            min-height: 100vh;
            background: #0B0E12;
        }

        @@media (max-width: 768px) {
            .afl-role-badge { display: none; }
            .afl-chip { display: none; }
        }
    </style>

    @await RenderSectionAsync("Head", required: false)
</head>
<body class="afl-shell">

<nav class="afl-navbar" role="navigation" aria-label="Affiliate navigation">
    <a class="afl-brand" asp-page="/AffiliateDashboard">
        <div class="afl-brand-mark">DW</div>
        <div>
            <div class="afl-brand-name">DeliveryWebLoL</div>
            <div class="afl-brand-sub">Affiliate Portal</div>
        </div>
    </a>

    <div class="afl-navbar-right">
        <span class="afl-role-badge">Affiliate</span>
        <div class="afl-chip afl-chip-purple">Orders</div>

        <button class="afl-icon-btn" title="Notifications" aria-label="Notifications">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/>
            </svg>
        </button>

            <form method="post" asp-page="/Logout">
                <button type="submit" class="al-nav-link" style="width:100%;color:rgba(255,77,106,0.75);border:none;background:none;cursor:pointer;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                        <polyline points="16 17 21 12 16 7" />
                        <line x1="21" y1="12" x2="9" y2="12" />
                    </svg>
                    Sign Out
                </button>
            </form>

        <div class="afl-avatar-wrap" id="aflAvatarWrap">
            <button class="afl-avatar" id="aflAvatarBtn" title="@username" aria-haspopup="true" aria-expanded="false">@initial</button>
            <div class="afl-dropdown" id="aflDropdown" role="menu">
                <div class="afl-dropdown-header">
                    <div class="afl-dropdown-name">@username</div>
                    <div class="afl-dropdown-sub">Affiliate · Signed in</div>
                </div>
                <a class="afl-dd-item" asp-page="/AffiliateDashboard" role="menuitem">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
                        <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
                    </svg>
                    My Orders
                </a>
                <div class="afl-dd-divider"></div>
                <form method="post" asp-page="/Logout">
                    <button type="submit" class="afl-dd-item logout" role="menuitem">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                        Sign Out
                    </button>
                </form>
            </div>
        </div>
    </div>
</nav>

<main class="afl-main" id="aflMain">
    @RenderBody()
</main>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script>
    window.__apiBase__ = @System.Text.Json.JsonSerializer.Serialize(Configuration["ApiBaseUrl"] ?? "");
    (function () {
        var avatarWrap = document.getElementById('aflAvatarWrap');
        var avatarBtn  = document.getElementById('aflAvatarBtn');
        avatarBtn.addEventListener('click', function(e) {
            e.stopPropagation();
            var open = avatarWrap.classList.toggle('open');
            avatarBtn.setAttribute('aria-expanded', open);
        });
        document.addEventListener('click', function() {
            avatarWrap.classList.remove('open');
            avatarBtn.setAttribute('aria-expanded', 'false');
        });
    })();
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
