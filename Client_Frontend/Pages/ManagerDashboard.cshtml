    </div>
</div>


@section Scripts {
<script src="~/js/dashboard.js"></script>
<script>
    // Populate create-order modal with item name from skin-card export button
    const _origOpen = window.openModal;
    window.openModal = function(id, data) {
        data = data || {};
        _origOpen(id, data);
        if (id === 'createOrderModal' && data.item) {
            document.getElementById('co-item').textContent = data.item + ' (' + (data.sku || '') + ')';
        }
    };
</script>
}
