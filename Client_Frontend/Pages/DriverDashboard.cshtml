@page
@model Client_Frontend.Pages.DriverDashboardModel
@{
    ViewData["Title"] = "Driver Dashboard — DeliveryWebLoL";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Driver Dashboard — view and manage your delivery orders." />
    <title>@ViewData["Title"]</title>
    <link rel="icon" href="~/favicon.ico" />
    <link rel="stylesheet" href="~/css/auth.css" />
    <link rel="stylesheet" href="~/css/dashboard.css" />
    <style>
        /* Driver-specific: no sidebar, simpler shell */
        .driver-shell { padding-top: var(--navbar-h); }
        .driver-main  { max-width: 840px; margin: 0 auto; padding: 28px 20px 60px; }
    </style>
</head>
<body class="dash-page">

<!-- ── Navbar ─────────────────────────────────────────── -->
<nav class="dash-navbar">
    <div class="dash-brand">
        <div class="mark">DW</div>
        <span class="brand-name">DeliveryWebLoL</span>
    </div>
    <div class="dash-navbar-right">
        <span class="dash-role-badge">Driver</span>

        <!-- Quick stats chips -->
        <div style="display:flex;gap:8px;" class="driver-chips">
            <div style="background:var(--bg-raised);border:1px solid var(--bg-border);border-radius:20px;padding:4px 12px;font-size:12px;color:var(--text-muted);">
                <span style="color:var(--yellow);font-weight:700;">3</span> Pending
            </div>
            <div style="background:var(--yellow);border-radius:20px;padding:4px 12px;font-size:12px;color:#111;font-weight:700;">
                2 Shipping
            </div>
        </div>

        <button class="dash-icon-btn" title="Notifications">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
            </svg>
        </button>
        <a class="dash-icon-btn" href="/Login" title="Sign out">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/>
                <line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
        </a>
        <div class="dash-avatar" title="Driver">D</div>
    </div>
</nav>

<!-- ── Main ───────────────────────────────────────────── -->
<div class="driver-shell">
    <main class="driver-main">

        <!-- Header row -->
        <div class="dash-page-header" style="display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:12px;">
            <div>
                <div class="dash-page-title">My Orders</div>
                <div class="dash-page-subtitle">Click any order to view details and update status</div>
            </div>
            <div style="display:flex;gap:8px;flex-wrap:wrap;" id="statusFilter">
                <button class="filter-pill active" data-filter="all" onclick="filterOrders(this,'all')">All</button>
                <button class="filter-pill" data-filter="pending"   onclick="filterOrders(this,'pending')">Pending</button>
                <button class="filter-pill" data-filter="shipping"  onclick="filterOrders(this,'shipping')">Shipping</button>
                <button class="filter-pill" data-filter="delivered" onclick="filterOrders(this,'delivered')">Delivered</button>
            </div>
        </div>

        <style>
            .filter-pill {
                padding: 6px 14px; border-radius: 20px; font-size: 12px; font-weight: 600;
                background: var(--bg-raised); border: 1px solid var(--bg-border);
                color: var(--text-muted); cursor: pointer;
                transition: background var(--t), color var(--t), border-color var(--t);
            }
            .filter-pill:hover { color: var(--text-primary); border-color: rgba(255,255,255,0.15); }
            .filter-pill.active { background: var(--yellow-dim); color: var(--yellow); border-color: rgba(245,199,27,0.35); }
        </style>

        <!-- KPI mini row -->
        <div class="kpi-grid mb-4" style="grid-template-columns:repeat(4,1fr)">
            <div class="kpi-card">
                <div class="kpi-value">7</div>
                <div class="kpi-label">Today's Orders</div>
            </div>
            <div class="kpi-card">
                <div class="kpi-value" style="color:var(--yellow)">3</div>
                <div class="kpi-label">Pending</div>
            </div>
            <div class="kpi-card">
                <div class="kpi-value" style="color:#60a5fa">2</div>
                <div class="kpi-label">Shipping</div>
            </div>
            <div class="kpi-card">
                <div class="kpi-value" style="color:#4ade80">2</div>
                <div class="kpi-label">Delivered</div>
            </div>
        </div>

        <!-- Order List -->
        <div class="order-list" id="orderList">

            @{
                var orders = new[] {
                    new {
                        Id="DWL-2024-0841", Status="pending",
                        Addr="45 Tran Hung Dao, Hoan Kiem, Hanoi",
                        Recipient="Nguyen Van An", Phone="0901 234 567",
                        Item="Express Parcel (EXP-001)", Weight="2kg",
                        Fee="45,000đ", ETA="Before 14:00",
                        Time="09:30 AM", Warehouse="HN-1 Hanoi Central"
                    },
                    new {
                        Id="DWL-2024-0842", Status="shipping",
                        Addr="12 Le Loi, Dong Da, Hanoi",
                        Recipient="Tran Thi Bich", Phone="0912 345 678",
                        Item="Standard Box (STD-002)", Weight="5kg",
                        Fee="25,000đ", ETA="Before 16:00",
                        Time="10:15 AM", Warehouse="HN-1 Hanoi Central"
                    },
                    new {
                        Id="DWL-2024-0843", Status="pending",
                        Addr="88 Nguyen Trai, Thanh Xuan, Hanoi",
                        Recipient="Le Van Cuong", Phone="0923 456 789",
                        Item="Fragile Glass Set (FRG-003)", Weight="1.5kg",
                        Fee="60,000đ", ETA="Before 17:00",
                        Time="11:00 AM", Warehouse="HN-2 Hanoi North"
                    },
                    new {
                        Id="DWL-2024-0840", Status="delivered",
                        Addr="5 Hoang Dieu, Ba Dinh, Hanoi",
                        Recipient="Pham Thi Dung", Phone="0934 567 890",
                        Item="Document Folder (DOC-005)", Weight="0.2kg",
                        Fee="15,000đ", ETA="Delivered at 08:45",
                        Time="07:00 AM", Warehouse="HN-1 Hanoi Central"
                    },
                    new {
                        Id="DWL-2024-0839", Status="shipping",
                        Addr="200 La Thanh, Dong Da, Hanoi",
                        Recipient="Hoang Van Em", Phone="0945 678 901",
                        Item="Cold Chain Bag (CCH-004)", Weight="3kg",
                        Fee="80,000đ", ETA="Before 13:00",
                        Time="08:30 AM", Warehouse="HN-2 Hanoi North"
                    },
                    new {
                        Id="DWL-2024-0838", Status="delivered",
                        Addr="99 Kim Ma, Ba Dinh, Hanoi",
                        Recipient="Vu Thi Hanh", Phone="0956 789 012",
                        Item="Economy Pouch (ECO-008)", Weight="0.5kg",
                        Fee="12,000đ", ETA="Delivered at 08:15",
                        Time="06:45 AM", Warehouse="HN-1 Hanoi Central"
                    },
                    new {
                        Id="DWL-2024-0844", Status="pending",
                        Addr="34 Dinh Tien Hoang, Hoan Kiem, Hanoi",
                        Recipient="Do Van Giang", Phone="0967 890 123",
                        Item="Overnight Pack (ONP-007)", Weight="2.5kg",
                        Fee="55,000đ", ETA="Before 18:00",
                        Time="11:45 AM", Warehouse="HN-1 Hanoi Central"
                    },
                };
            }

            @foreach (var o in orders)
            {
                var badgeCls = o.Status switch {
                    "pending"   => "badge-pending",
                    "shipping"  => "badge-shipping",
                    "delivered" => "badge-delivered",
                    _           => "badge-cancelled"
                };
                var badgeTxt = o.Status switch {
                    "pending"   => "Pending",
                    "shipping"  => "Shipping",
                    "delivered" => "Delivered",
                    _           => "Cancelled"
                };
                <!-- Each order row + collapsible detail panel are siblings -->
                <div>
                    <div class="order-row" data-status="@o.Status">
                        <div class="order-row-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
                                <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
                            </svg>
                        </div>
                        <div class="order-row-info">
                            <div class="order-row-id">@o.Id</div>
                            <div class="order-row-addr">@o.Addr</div>
                        </div>
                        <div class="order-row-right">
                            <span class="order-row-time">@o.Time</span>
                            <span class="badge @badgeCls">@badgeTxt</span>
                        </div>
                    </div>
                    <!-- Detail panel (hidden until click) -->
                    <div class="order-detail-panel">
                        <div class="detail-grid">
                            <div class="detail-kv"><label>Order ID</label><span>@o.Id</span></div>
                            <div class="detail-kv"><label>Recipient</label><span>@o.Recipient</span></div>
                            <div class="detail-kv"><label>Phone</label><span>@o.Phone</span></div>
                            <div class="detail-kv"><label>Address</label><span>@o.Addr</span></div>
                            <div class="detail-kv"><label>Item</label><span>@o.Item</span></div>
                            <div class="detail-kv"><label>Weight</label><span>@o.Weight</span></div>
                            <div class="detail-kv"><label>Fee</label><span style="color:var(--yellow)">@o.Fee</span></div>
                            <div class="detail-kv"><label>ETA</label><span>@o.ETA</span></div>
                            <div class="detail-kv"><label>Warehouse</label><span>@o.Warehouse</span></div>
                            <div class="detail-kv"><label>Current Status</label><span class="badge @badgeCls">@badgeTxt</span></div>
                        </div>
                        @if (o.Status != "delivered")
                        {
                            <button class="btn-update-status"
                                    onclick="openModal('statusModal', {orderId:'@o.Id', currentStatus:'@o.Status'})">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="20 6 9 17 4 12"/>
                                </svg>
                                Update Status
                            </button>
                        }
                        else
                        {
                            <div style="font-size:13px;color:#4ade80;display:flex;align-items:center;gap:6px;">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                                Order delivered successfully
                            </div>
                        }
                    </div>
                </div>
            }

        </div><!-- /order-list -->
    </main>
</div>

<!-- ══ MODAL: Update Status ══ -->
<div class="modal-overlay" id="statusModal">
    <div class="modal-box">
        <div class="modal-header">
            <div class="modal-title">Update Order Status</div>
            <button class="modal-close" onclick="closeModal('statusModal')">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <div style="font-size:13px;color:var(--text-muted);margin-bottom:18px;">
            Order: <strong id="sm-orderId" style="color:var(--yellow)">—</strong>
        </div>
        <div class="modal-field">
            <label class="modal-label">Select New Status</label>
            <div class="status-option-grid">
                <div class="status-option" data-status="pending">
                    <span class="badge badge-pending" style="pointer-events:none">Pending</span>
                </div>
                <div class="status-option selected" data-status="shipping">
                    <span class="badge badge-shipping" style="pointer-events:none">Shipping</span>
                </div>
                <div class="status-option" data-status="delivered">
                    <span class="badge badge-delivered" style="pointer-events:none">Delivered</span>
                </div>
                <div class="status-option" data-status="cancelled">
                    <span class="badge badge-cancelled" style="pointer-events:none">Cancelled</span>
                </div>
            </div>
            <input type="hidden" name="newStatus" value="shipping" />
        </div>
        <div class="modal-field">
            <label class="modal-label" for="sm-note">Note (optional)</label>
            <input class="modal-input" id="sm-note" placeholder="E.g. Customer not at home..." />
        </div>
        <div class="modal-footer">
            <button class="btn-modal-cancel" onclick="closeModal('statusModal')">Cancel</button>
            <button class="btn-modal-save" onclick="closeModal('statusModal')">Confirm Update</button>
        </div>
    </div>
</div>

<script src="~/js/dashboard.js"></script>
<script>
    // Attach detail panel expand to each order row
    document.querySelectorAll('.order-row').forEach(row => {
        row.addEventListener('click', e => {
            if (e.target.closest('button')) return;
            const wrapper = row.parentElement;
            const panel = wrapper.querySelector('.order-detail-panel');
            if (!panel) return;
            const isOpen = panel.classList.contains('open');
            document.querySelectorAll('.order-detail-panel.open').forEach(p => p.classList.remove('open'));
            document.querySelectorAll('.order-row.active').forEach(r => r.classList.remove('active'));
            if (!isOpen) { panel.classList.add('open'); row.classList.add('active'); }
        });
    });

    // Populate statusModal
    const _o = window.openModal;
    window.openModal = function(id, data = {}) {
        _o(id, data);
        if (id === 'statusModal' && data.orderId) {
            document.getElementById('sm-orderId').textContent = data.orderId;
            const opt = document.querySelector(`.status-option[data-status="${data.currentStatus}"]`);
            if (opt) {
                document.querySelectorAll('.status-option').forEach(o => o.classList.remove('selected'));
                opt.classList.add('selected');
            }
        }
    };

    // Filter pills
    function filterOrders(btn, status) {
        document.querySelectorAll('.filter-pill').forEach(p => p.classList.remove('active'));
        btn.classList.add('active');
        document.querySelectorAll('.order-row').forEach(row => {
            const wrapper = row.parentElement;
            if (status === 'all' || row.dataset.status === status) {
                wrapper.style.display = '';
            } else {
                wrapper.style.display = 'none';
                const panel = wrapper.querySelector('.order-detail-panel');
                if (panel) panel.classList.remove('open');
            }
        });
    }
</script>
</body>
</html>
