@page
@model Client_Frontend.Pages.DriverDashboardModel
@{
    ViewData["Title"] = "My Orders";
    Layout = "_DriverLayout";
}

@section Head {
    <meta name="description" content="Driver Dashboard — view and manage your delivery orders." />
    <style>
        .driver-content { max-width: 860px; margin: 0 auto; padding: 28px 20px 60px; }
        .filter-pill {
            padding: 6px 14px; border-radius: 20px; font-size: 12px; font-weight: 600;
            background: var(--bg-raised); border: 1px solid var(--bg-border);
            color: var(--text-muted); cursor: pointer;
            transition: background var(--t), color var(--t), border-color var(--t);
        }
        .filter-pill:hover { color: var(--text-primary); border-color: rgba(255,255,255,0.15); }
        .filter-pill.active { background: var(--yellow-dim); color: var(--yellow); border-color: rgba(245,199,27,0.35); }
    </style>
}

<div class="driver-content">
    @Html.AntiForgeryToken()

    <!-- Header row -->
    <div class="dash-page-header" style="display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:12px;">
        <div>
            <div class="dash-page-title">My Orders</div>
            <div class="dash-page-subtitle">Orders from your affiliated warehouse</div>
        </div>
        <div style="display:flex;gap:8px;flex-wrap:wrap;" id="statusFilter">
            <button class="filter-pill active"  data-filter="all"       onclick="filterOrders(this,'all')">All</button>
            <button class="filter-pill"         data-filter="ready"     onclick="filterOrders(this,'ready')">Ready</button>
            <button class="filter-pill"         data-filter="intransit" onclick="filterOrders(this,'intransit')">In Transit</button>
            <button class="filter-pill"         data-filter="delivered" onclick="filterOrders(this,'delivered')">Delivered</button>
        </div>
    </div>

    <!-- Order List -->
    <div class="order-list" id="orderList">
        @if (Model.Orders == null || Model.Orders.Count == 0)
        {
            <div style="padding:18px;color:rgba(255,255,255,0.45);">No orders for your warehouse.</div>
        }
        else
        {
            @* Replace the per-order structure to remove the outer wrapper div *@
            @foreach (var o in Model.Orders)
            {
                var badgeCls = o.StatusKey switch { "ready" => "badge-pending", "intransit" => "badge-shipping", "delivered" => "badge-delivered", _ => "badge-pending" };
                var badgeTxt = o.StatusKey switch { "ready" => "Ready", "intransit" => "In Transit", "delivered" => "Delivered", _ => o.StatusText };

                <div class="order-row" data-status="@o.StatusKey">
                    <div class="order-row-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                    </div>
                    <div class="order-row-info">
                        <div class="order-row-id">@o.OrderId</div>
                        <div class="order-row-addr">From <strong>@o.Source</strong> → <strong>@o.Destination</strong></div>
                    </div>
                    <div class="order-row-right">
                        <span class="order-row-time">@o.CreatedAt.ToString("HH:mm")</span>
                        <span class="badge @badgeCls">@badgeTxt</span>
                    </div>
                </div>

                <div class="order-detail-panel">
                    <div class="detail-grid">
                        <div class="detail-kv"><label>Order ID</label><span>@o.OrderId</span></div>
                        <div class="detail-kv"><label>Requested By</label><span>@(string.IsNullOrWhiteSpace(o.RequestedBy) ? "—" : o.RequestedBy)</span></div>
                        <div class="detail-kv"><label>Warehouse</label><span>@o.Source</span></div>
                        <div class="detail-kv"><label>Destination</label><span>@o.Destination</span></div>
                        <div class="detail-kv"><label>Status</label><span class="badge @badgeCls">@badgeTxt</span></div>
                    </div>

                    <div style="margin-top:12px; padding:12px; border:1px solid rgba(255,255,255,0.08); border-radius:12px; background:rgba(0,0,0,0.18);">
                        <div style="font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.4);margin-bottom:8px;">Items</div>
                        <div style="overflow:auto;">
                            <table style="width:100%;border-collapse:collapse;font-size:12.5px;">
                                <thead>
                                    <tr>
                                        <th style="text-align:left;padding:8px 10px;color:rgba(255,255,255,0.35);font-size:10px;letter-spacing:0.12em;text-transform:uppercase;border-bottom:1px solid rgba(255,255,255,0.08);">SKU</th>
                                        <th style="text-align:left;padding:8px 10px;color:rgba(255,255,255,0.35);font-size:10px;letter-spacing:0.12em;text-transform:uppercase;border-bottom:1px solid rgba(255,255,255,0.08);">Name</th>
                                        <th style="text-align:left;padding:8px 10px;color:rgba(255,255,255,0.35);font-size:10px;letter-spacing:0.12em;text-transform:uppercase;border-bottom:1px solid rgba(255,255,255,0.08);">Unit</th>
                                        <th style="text-align:right;padding:8px 10px;color:rgba(255,255,255,0.35);font-size:10px;letter-spacing:0.12em;text-transform:uppercase;border-bottom:1px solid rgba(255,255,255,0.08);">Qty</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @foreach (var li in o.Items)
                                {
                                    <tr>
                                        <td style="padding:9px 10px;border-bottom:1px solid rgba(255,255,255,0.04);font-family:monospace;color:rgba(255,255,255,0.75);">@li.SKU</td>
                                        <td style="padding:9px 10px;border-bottom:1px solid rgba(255,255,255,0.04);color:#fff;">@li.Name</td>
                                        <td style="padding:9px 10px;border-bottom:1px solid rgba(255,255,255,0.04);color:rgba(255,255,255,0.55);">@(li.Unit ?? "—")</td>
                                        <td style="padding:9px 10px;border-bottom:1px solid rgba(255,255,255,0.04);text-align:right;color:#F5C71B;font-family:'Russo One', sans-serif;">@li.Quantity</td>
                                    </tr>
                                }
                                @if (o.Items == null || o.Items.Count == 0)
                                {
                                    <tr><td colspan="4" style="padding:10px;color:rgba(255,255,255,0.35);">No items.</td></tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div style="margin-top:12px; display:flex; gap:10px; flex-wrap:wrap;">
                        @if (o.Status == 3)
                        {
                            <button type="button" class="btn-update-status" onclick="pickupOrder(event,'@o.OrderId')">Pick up (→ In Transit)</button>
                        }
                        @if (o.Status == 4)
                        {
                            <button type="button" class="btn-update-status" onclick="deliverOrder(event,'@o.OrderId')">Confirm Delivered</button>
                        }
                    </div>
                </div>
            }
        }
    </div>

</div><!-- /driver-content -->

<!-- ══ MODAL: Update Status ══ -->
<div class="modal-overlay" id="statusModal">
    <div class="modal-box">
        <div class="modal-header">
            <div class="modal-title">Update Order Status</div>
            <button class="modal-close" onclick="closeModal('statusModal')"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
        </div>
        <div style="font-size:13px;color:var(--text-muted);margin-bottom:18px;">
            Order: <strong id="sm-orderId" style="color:var(--yellow)">—</strong>
        </div>
        <div class="modal-field">
            <label class="modal-label">Select New Status</label>
            <div class="status-option-grid">
                <div class="status-option" data-status="pending"><span class="badge badge-pending" style="pointer-events:none">Pending</span></div>
                <div class="status-option selected" data-status="shipping"><span class="badge badge-shipping" style="pointer-events:none">Shipping</span></div>
                <div class="status-option" data-status="delivered"><span class="badge badge-delivered" style="pointer-events:none">Delivered</span></div>
                <div class="status-option" data-status="cancelled"><span class="badge badge-cancelled" style="pointer-events:none">Cancelled</span></div>
            </div>
        </div>
        <div class="modal-field">
            <label class="modal-label" for="sm-note">Note (optional)</label>
            <input class="modal-input" id="sm-note" placeholder="E.g. Customer not at home..." />
        </div>
        <div class="modal-footer">
            <button class="btn-modal-cancel" onclick="closeModal('statusModal')">Cancel</button>
            <button class="btn-modal-save"   onclick="closeModal('statusModal')">Confirm Update</button>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/js/dashboard.js"></script>
<script>
    window.filterOrders = function(btn, status) {
        document.querySelectorAll('.filter-pill').forEach(function(p) { p.classList.remove('active'); });
        btn.classList.add('active');
        document.querySelectorAll('.order-row').forEach(function(row) {
            var panel = row.nextElementSibling;
            var show = (status === 'all' || row.dataset.status === status);
            row.style.display = show ? '' : 'none';
            if (panel && panel.classList.contains('order-detail-panel')) {
                panel.style.display = show ? '' : 'none';
                panel.classList.remove('open');
            }
        });
    }

    async function postToHandler(handler, orderId){
        var fd = new FormData();
        var tokenEl = document.querySelector('input[name="__RequestVerificationToken"]');
        if (tokenEl) fd.append('__RequestVerificationToken', tokenEl.value);
        fd.append('orderId', orderId);

        var res = await fetch('?handler=' + handler, { method: 'POST', body: fd });
        var json = await res.json().catch(function(){ return null; });
        if (!res.ok || !json || json.success !== true) {
            alert((json && json.message) ? json.message : ('Error ' + res.status));
            return false;
        }
        return true;
    }

    window.pickupOrder = async function(ev, orderId){
        ev.preventDefault();
        ev.stopPropagation();
        if (!confirm('Pick up this order? Status will become InTransit.')) return;
        if (await postToHandler('Pickup', orderId)) location.reload();
    }

    window.deliverOrder = async function(ev, orderId){
        ev.preventDefault();
        ev.stopPropagation();
        if (!confirm('Confirm delivered?')) return;
        if (await postToHandler('Deliver', orderId)) location.reload();
    }
</script>
}
