@page
@model Client_Frontend.Pages.AffiliateDashboardModel
@{
    ViewData["Title"] = "My Orders";
    Layout = "_AffiliateLayout";
}

@section Head {
<style>
    .af-content { max-width: 1100px; margin: 0 auto; padding: 28px 20px 60px; }

    .af-header { display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap: 12px; }
    .af-title { font-family: 'Russo One', sans-serif; font-size: 22px; letter-spacing:0.02em; color: #fff; }
    .af-sub { font-size: 13px; color: rgba(255,255,255,0.45); margin-top: 4px; }

    .af-actions { display:flex; gap: 10px; flex-wrap: wrap; align-items:center; }
    .af-btn {
        display:inline-flex; align-items:center; gap: 8px;
        padding: 9px 14px;
        border-radius: 10px;
        border: 1px solid rgba(139,92,246,0.28);
        background: rgba(139,92,246,0.14);
        color: rgba(167,139,250,0.95);
        font-family: 'Russo One', sans-serif;
        font-size: 11.5px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        cursor: pointer;
        transition: filter 180ms ease, border-color 180ms ease;
    }
    .af-btn:hover { filter: brightness(1.12); border-color: rgba(139,92,246,0.45); }

    .af-filters { display:flex; gap: 8px; flex-wrap:wrap; }
    .af-pill {
        padding: 6px 14px; border-radius: 999px;
        font-size: 12px; font-weight: 700;
        background: #171C25;
        border: 1px solid #1C222B;
        color: rgba(255,255,255,0.55);
        cursor: pointer;
        transition: background 180ms ease, color 180ms ease, border-color 180ms ease;
    }
    .af-pill:hover { color:#fff; border-color: rgba(255,255,255,0.15); }
    .af-pill.active { background: rgba(139,92,246,0.16); border-color: rgba(139,92,246,0.4); color: rgba(167,139,250,0.95); }

    .order-row { cursor: pointer; }
    .badge { font-family: 'Chakra Petch', sans-serif; }

    .af-badge {
        display:inline-flex; align-items:center; gap: 6px;
        padding: 4px 10px; border-radius: 999px;
        font-size: 10px; font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        border: 1px solid rgba(255,255,255,0.10);
        background: rgba(255,255,255,0.04);
        color: rgba(255,255,255,0.75);
    }
    .af-pending     { background: rgba(245,199,27,0.10); border-color: rgba(245,199,27,0.25); color: rgba(245,199,27,0.95); }
    .af-approved    { background: rgba(139,92,246,0.12); border-color: rgba(139,92,246,0.28); color: rgba(167,139,250,0.95); }
    .af-preparing   { background: rgba(59,130,246,0.10); border-color: rgba(59,130,246,0.25); color: rgba(96,165,250,0.95); }
    .af-ready       { background: rgba(34,197,94,0.10); border-color: rgba(34,197,94,0.22); color: rgba(74,222,128,0.95); }
    .af-intransit   { background: rgba(6,182,212,0.10); border-color: rgba(6,182,212,0.25); color: rgba(34,211,238,0.95); }
    .af-completed   { background: rgba(34,197,94,0.10); border-color: rgba(34,197,94,0.25); color: rgba(74,222,128,0.95); }
    .af-cancelled   { background: rgba(255,77,106,0.10); border-color: rgba(255,77,106,0.25); color: rgba(255,77,106,0.95); }

    .af-modal-wrap {
        position: fixed;
        inset: 0;
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 2000;
        padding: 16px;
    }
    .af-modal-wrap.open { display: flex; }
    .af-modal-wrap::before {
        content: '';
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.78);
        backdrop-filter: blur(4px);
    }
    .af-modal {
        position: relative;
        z-index: 1;
        width: 100%;
        max-width: 920px;
        background: #12161D;
        border: 1px solid rgba(139,92,246,0.25);
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 24px 64px rgba(0,0,0,0.75);
    }
    .af-modal-head { padding: 14px 16px; border-bottom: 1px solid #1C222B; display:flex; justify-content:space-between; align-items:center; }
    .af-modal-title { font-family: 'Russo One', sans-serif; font-size: 13px; color: #fff; letter-spacing: 0.03em; }
    .af-modal-x {
        width: 30px; height: 30px; border-radius: 9px;
        background: #171C25; border: 1px solid #1C222B;
        color: rgba(255,255,255,0.7); cursor: pointer;
    }
    .af-modal-x:hover { color:#FF4D6A; border-color: rgba(255,77,106,0.3); }
    .af-modal-body { padding: 16px; }
    .af-modal-foot { padding: 14px 16px; border-top: 1px solid #1C222B; display:flex; justify-content:flex-end; gap: 10px; }

    .af-input {
        width: 100%;
        background: #0B0E12;
        border: 1px solid #1C222B;
        border-radius: 10px;
        color: #fff;
        padding: 10px 12px;
        outline: none;
        font-size: 13px;
    }
    .af-input:focus { border-color: #8B5CF6; box-shadow: 0 0 0 3px rgba(139,92,246,0.12); }

    .af-btn-cancel {
        padding: 9px 16px;
        border-radius: 10px;
        background: #171C25;
        border: 1px solid #1C222B;
        color: rgba(255,255,255,0.7);
        cursor: pointer;
    }
    .af-btn-cancel:hover { color:#fff; border-color: rgba(255,255,255,0.15); }

    .af-btn-primary {
        padding: 9px 18px;
        border-radius: 10px;
        background: #8B5CF6;
        border: none;
        color: #fff;
        cursor: pointer;
        font-family: 'Russo One', sans-serif;
        font-size: 11.5px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
    }

    .af-grid2 { display:grid; grid-template-columns: 1.1fr 0.9fr; gap: 14px; }
    .af-panel { border: 1px solid #1C222B; border-radius: 12px; background:#0f131a; overflow:hidden; }
    .af-panel-head { padding: 10px 12px; border-bottom: 1px solid #1C222B; display:flex; align-items:center; justify-content:space-between; gap: 10px; }
    .af-panel-title { font-weight: 800; letter-spacing:0.08em; text-transform:uppercase; font-size: 10.5px; color: rgba(255,255,255,0.6); }
    .af-panel-body { max-height: 380px; overflow:auto; }

    .af-item-row { display:flex; align-items:center; justify-content:space-between; gap: 10px; padding: 10px 12px; border-bottom: 1px solid rgba(255,255,255,0.05); }
    .af-item-row:last-child { border-bottom:none; }
    .af-item-name { font-weight: 800; color:#fff; font-size: 13px; }
    .af-item-meta { font-size: 11.5px; color: rgba(255,255,255,0.45); margin-top: 2px; }
    .af-item-qty { font-family: 'Chakra Petch', monospace; font-size: 12px; color: rgba(245,199,27,0.9); }

    .af-btn-mini { padding: 6px 10px; border-radius: 10px; border: 1px solid rgba(139,92,246,0.28); background: rgba(139,92,246,0.14); color: rgba(167,139,250,0.95); cursor:pointer; font-size: 11px; }
    .af-btn-mini:hover { filter: brightness(1.12); }

    .af-li-row { display:flex; align-items:center; gap: 10px; padding: 10px 12px; border-bottom: 1px solid rgba(255,255,255,0.05); }
    .af-li-row:last-child { border-bottom:none; }
    .af-li-sku { font-family: 'Chakra Petch', monospace; color: rgba(255,255,255,0.7); font-size: 12px; width: 90px; }
    .af-li-title { flex:1; min-width: 0; }
    .af-li-title strong { display:block; white-space: nowrap; overflow:hidden; text-overflow: ellipsis; }
    .af-li-qty { width: 110px; }

    .af-alert { display:none; margin-bottom: 10px; padding: 10px 12px; border-radius: 10px; border: 1px solid rgba(255,77,106,0.25); background: rgba(255,77,106,0.09); color: #FF4D6A; font-size: 12.5px; }
    .af-alert.show { display:block; }

    .af-claim {
        margin-top: 16px;
        border: 1px solid rgba(255,77,106,0.25);
        background: rgba(255,77,106,0.08);
        border-radius: 14px;
        padding: 14px 16px;
    }
    .af-claim-title {
        font-family: 'Russo One', sans-serif;
        font-size: 13px;
        letter-spacing: 0.03em;
        color: #fff;
        margin-bottom: 6px;
    }
    .af-claim-sub {
        font-size: 12.5px;
        color: rgba(255,255,255,0.55);
        margin-bottom: 12px;
        line-height: 1.5;
    }
    .af-claim-row {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        align-items: center;
    }
    .af-claim-row .af-input { flex: 1; min-width: 280px; }
    .af-claim-msg {
        margin-top: 10px;
        font-size: 12.5px;
        color: rgba(255,255,255,0.7);
    }

    /* Order rows */
    .order-list { display:flex; flex-direction:column; gap: 8px; }
    .order-row {
        display: flex; align-items:center; gap: 14px;
        background: #12161D; border: 1px solid #1C222B; border-radius: 12px;
        padding: 13px 16px;
        transition: border-color 180ms ease;
    }
    .order-row:hover { border-color: rgba(139,92,246,0.3); }
    .order-row-icon { flex-shrink: 0; }
    .order-row-info { flex: 1; min-width: 0; }
    .order-row-id { font-family: monospace; font-size: 11.5px; color: rgba(255,255,255,0.55); white-space: nowrap; overflow:hidden; text-overflow: ellipsis; }
    .order-row-addr { font-size: 12px; color: rgba(255,255,255,0.35); margin-top: 2px; white-space: nowrap; overflow:hidden; text-overflow: ellipsis; }
    .order-row-right { display:flex; align-items: center; gap: 10px; flex-shrink: 0; }
    .order-row-time { font-size: 11.5px; color: rgba(255,255,255,0.35); }

    .order-detail-panel {
        display: none;
        background: #0B0E12;
        border: 1px solid #1C222B;
        border-top: none;
        border-radius: 0 0 12px 12px;
        padding: 16px;
        margin-top: -4px;
    }
    .order-detail-panel.open { display: block; }
    .detail-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }
    @@media (max-width: 700px) { .detail-grid { grid-template-columns: repeat(2, 1fr); } }
    .detail-kv label { display:block; font-size: 10px; font-weight: 800; letter-spacing: 0.1em; text-transform:uppercase; color: rgba(255,255,255,0.3); margin-bottom: 3px; }
    .detail-kv span  { font-size: 12.5px; color: rgba(255,255,255,0.75); }
</style>
}

<div class="af-content">
    @Html.AntiForgeryToken()

    <div class="af-header">
        <div>
            <div class="af-title">My Orders</div>
            <div class="af-sub">Track all orders created by your affiliate account</div>
        </div>
        <div class="af-actions">
            <button class="af-btn" type="button" id="afBtnCreate">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Create Order
            </button>
        </div>
    </div>

    @{
        var claimSuccess = !string.IsNullOrWhiteSpace(Model.ClaimMessage) && Model.ClaimMessage.StartsWith("Affiliation claimed");
    }
    @if (Model.NeedAffiliationClaim && !claimSuccess)
    {
        <div class="af-claim">
            <div class="af-claim-title">Missing affiliation</div>
            <div class="af-claim-sub">
                Your account is not linked to a warehouse yet. Paste the <strong>Affiliate Location Code (GUID)</strong> provided by your manager to claim your affiliation.
            </div>
            <form method="post" asp-page-handler="ClaimAffiliation">
                @Html.AntiForgeryToken()
                <div class="af-claim-row">
                    <input class="af-input" asp-for="ClaimCode" placeholder="e.g. 2f5b2c2f-7d7c-4f05-9a5a-5d4f8b6c9d12" autocomplete="off" />
                    <button class="af-btn-primary" type="submit">Claim</button>
                </div>
            </form>
            @if (!string.IsNullOrWhiteSpace(Model.ClaimMessage))
            {
                <div class="af-claim-msg">@Model.ClaimMessage</div>
            }
        </div>
    }
    @if (claimSuccess)
    {
        <div class="af-claim" style="border-color:rgba(34,197,94,0.35);background:rgba(34,197,94,0.06);">
            <div class="af-claim-title" style="color:#4ade80;">&#10003; Affiliation Active</div>
            <div class="af-claim-sub">@Model.ClaimMessage &mdash; reload the page to see your full dashboard.</div>
        </div>
    }

    <div style="margin-top:14px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;">
        <div class="af-filters" id="afStatusFilter">
            <button class="af-pill active" data-filter="all" type="button">All</button>
            <button class="af-pill" data-filter="pending" type="button">Pending</button>
            <button class="af-pill" data-filter="approved" type="button">Approved</button>
            <button class="af-pill" data-filter="preparing" type="button">Preparing</button>
            <button class="af-pill" data-filter="ready" type="button">Ready</button>
            <button class="af-pill" data-filter="intransit" type="button">InTransit</button>
            <button class="af-pill" data-filter="completed" type="button">Completed</button>
            <button class="af-pill" data-filter="cancelled" type="button">Cancelled</button>
        </div>
    </div>

    <div class="order-list" id="afOrderList" style="margin-top:16px;">
        @foreach (var o in Model.Orders)
        {
            <div>
                <div class="order-row" data-status="@o.StatusKey">
                    <div class="order-row-icon" style="color:#a78bfa;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="1" y="3" width="15" height="13"/>
                            <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
                            <circle cx="5.5" cy="18.5" r="2.5"/>
                            <circle cx="18.5" cy="18.5" r="2.5"/>
                        </svg>
                    </div>
                    <div class="order-row-info">
                        <div class="order-row-id">@o.OrderId</div>
                        <div class="order-row-addr">@o.Destination</div>
                    </div>
                    <div class="order-row-right">
                        <span class="order-row-time">@o.CreatedAt.ToString("HH:mm")</span>
                        <span class="af-badge @o.BadgeCss">@o.StatusKey</span>
                    </div>
                </div>
                <div class="order-detail-panel">
                    <div class="detail-grid">
                        <div class="detail-kv"><label>Order ID</label><span>@o.OrderId</span></div>
                        <div class="detail-kv"><label>Created</label><span>@o.CreatedAt.ToString("yyyy-MM-dd HH:mm")</span></div>
                        <div class="detail-kv"><label>Type</label><span>@o.OrderType</span></div>
                        <div class="detail-kv"><label>Status</label><span class="af-badge @o.BadgeCss">@o.StatusKey</span></div>
                        <div class="detail-kv"><label>Destination</label><span>@o.Destination</span></div>
                        <div class="detail-kv"><label>Items</label><span>@(o.Note ?? "&mdash;")</span></div>
                    </div>

                    @if (o.StatusKey == "delivered")
                    {
                        <div style="margin-top:12px; display:flex; gap:10px; flex-wrap:wrap;">
                            <button type="button" class="btn-update-status" onclick="completeOrder(event,'@o.OrderId')">Complete Order</button>
                        </div>
                    }
                    @if (o.StatusKey == "pending")
                    {
                        <div style="margin-top:12px; display:flex; gap:10px; flex-wrap:wrap;">
                            <button type="button" class="btn-update-status" style="background:rgba(255,77,106,0.12);border:1px solid rgba(255,77,106,0.3);color:#FF4D6A;box-shadow:none;" onclick="cancelOrder(event,'@o.OrderId')">Cancel Order</button>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

</div>

<!-- Create Order Modal -->
<div class="af-modal-wrap" id="afCreateModal" role="dialog" aria-modal="true" aria-label="Create order">
    <div class="af-modal">
        <div class="af-modal-head">
            <div class="af-modal-title">Create Order @(!string.IsNullOrWhiteSpace(Model.WarehouseName) ? $"— {Model.WarehouseName}" : "")</div>
            <button type="button" class="af-modal-x" id="afModalClose">&#10005;</button>
        </div>
        <div class="af-modal-body">
            <div class="af-alert" id="afCreateErr"></div>

            <div class="af-grid2">
                <div class="af-panel">
                    <div class="af-panel-head">
                        <div class="af-panel-title">Warehouse Items</div>
                        <input class="af-input" id="afItemSearch" placeholder="Search SKU/Name..." style="max-width:320px;" />
                    </div>
                    <div class="af-panel-body" id="afItemList">
                        @foreach (var it in Model.WarehouseItems)
                        {
                            <div class="af-item-row" data-search="@((it.SKU + " " + it.Name).ToLowerInvariant())" data-itemid="@it.ItemId" data-sku="@it.SKU" data-name="@it.Name" data-unit="@(it.Unit ?? "")" data-avail="@it.Quantity">
                                <div>
                                    <div class="af-item-name">@it.Name</div>
                                    <div class="af-item-meta">@it.SKU &middot; @(it.Unit ?? "—")</div>
                                </div>
                                <div style="display:flex;align-items:center;gap:10px;">
                                    <div class="af-item-qty" title="Available">@it.Quantity</div>
                                    <button type="button" class="af-btn-mini" onclick="addToCart(this)">Add</button>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="af-panel">
                    <div class="af-panel-head">
                        <div class="af-panel-title">Order Items</div>
                        <span style="font-size:11px;color:rgba(255,255,255,0.4);">Pick quantities</span>
                    </div>
                    <div class="af-panel-body" id="afCart"></div>

                    <div style="padding:12px;border-top:1px solid #1C222B;display:grid;gap:10px;">
                        <div>
                            <label style="display:block;font-size:10px;font-weight:800;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.36);margin-bottom:6px;">Destination Location ID</label>
                            <input class="af-input" id="afDestLocationId" placeholder="GUID of destination location" value="@(Model.DestinationLocationId?.ToString() ?? "")" readonly />
                            <div style="margin-top:6px;font-size:12px;color:rgba(255,255,255,0.4);">Destination is your affiliate location.</div>
                        </div>
                        <input type="hidden" id="afWarehouseLocationId" value="@(Model.WarehouseLocationId?.ToString() ?? "")" />
                    </div>
                </div>
            </div>
        </div>
        <div class="af-modal-foot">
            <button type="button" class="af-btn-cancel" id="afModalCancel">Cancel</button>
            <button type="button" class="af-btn-primary" id="afModalCreate">Create</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    'use strict';

    // Expand/collapse order rows
    document.querySelectorAll('#afOrderList .order-row').forEach(function(row){
        row.addEventListener('click', function(){
            var panel = row.parentElement?.querySelector('.order-detail-panel');
            if (panel) panel.classList.toggle('open');
        });
    });

    // Status filter pills
    var filterBar = document.getElementById('afStatusFilter');
    filterBar?.querySelectorAll('button[data-filter]').forEach(function(btn){
        btn.addEventListener('click', function(){
            filterBar.querySelectorAll('.af-pill').forEach(function(p){ p.classList.remove('active'); });
            btn.classList.add('active');
            var f = btn.getAttribute('data-filter');
            document.querySelectorAll('#afOrderList .order-row').forEach(function(row){
                var wrapper = row.parentElement;
                if (f === 'all' || row.dataset.status === f) wrapper.style.display = '';
                else {
                    wrapper.style.display = 'none';
                    var panel = wrapper.querySelector('.order-detail-panel');
                    if (panel) panel.classList.remove('open');
                }
            });
        });
    });

    // Modal
    var modal = document.getElementById('afCreateModal');
    function openModal(){ modal.classList.add('open'); }
    function closeModal(){ modal.classList.remove('open'); hideErr(); }

    document.getElementById('afBtnCreate')?.addEventListener('click', openModal);
    document.getElementById('afModalClose')?.addEventListener('click', closeModal);
    document.getElementById('afModalCancel')?.addEventListener('click', closeModal);
    modal?.addEventListener('click', function(e){ if (e.target === modal) closeModal(); });

    // Search warehouse items
    var itemSearch = document.getElementById('afItemSearch');
    itemSearch?.addEventListener('input', function(){
        var q = (itemSearch.value || '').trim().toLowerCase();
        document.querySelectorAll('#afItemList .af-item-row').forEach(function(r){
            var hay = r.getAttribute('data-search') || '';
            r.style.display = (q === '' || hay.indexOf(q) >= 0) ? '' : 'none';
        });
    });

    // Cart state
    var cart = new Map();
    var cartEl = document.getElementById('afCart');

    window.addToCart = function(btn){
        var row = btn.closest('.af-item-row');
        if (!row) return;
        var itemId = row.getAttribute('data-itemid');
        var sku = row.getAttribute('data-sku');
        var name = row.getAttribute('data-name');
        var unit = row.getAttribute('data-unit') || '';
        var avail = parseFloat(row.getAttribute('data-avail') || '0');

        if (!cart.has(itemId)) cart.set(itemId, { itemId: itemId, sku: sku, name: name, unit: unit, qty: 1, avail: avail });
        renderCart();
    };

    function renderCart(){
        if (!cartEl) return;
        cartEl.innerHTML = '';
        if (cart.size === 0){
            cartEl.innerHTML = '<div style="padding:14px;color:rgba(255,255,255,0.35);font-size:13px;">No items added.</div>';
            return;
        }

        cart.forEach(function(v){
            var wrap = document.createElement('div');
            wrap.className = 'af-li-row';
            wrap.innerHTML =
                '<div class="af-li-sku">' + v.sku + '</div>' +
                '<div class="af-li-title"><strong>' + v.name + '</strong><div style="font-size:11.5px;color:rgba(255,255,255,0.45);">' + (v.unit || '—') + ' &middot; Available ' + v.avail + '</div></div>' +
                '<input class="af-input af-li-qty" type="number" min="0.01" step="0.01" value="' + v.qty + '" />' +
                '<button type="button" class="af-btn-mini" style="border-color:rgba(255,77,106,0.3);background:rgba(255,77,106,0.12);color:rgba(255,77,106,0.95);" title="Remove">Remove</button>';

            var qtyInput = wrap.querySelector('input');
            qtyInput.addEventListener('input', function(){
                var q = parseFloat(qtyInput.value || '0');
                v.qty = isNaN(q) ? 0 : q;
            });

            var rm = wrap.querySelector('button');
            rm.addEventListener('click', function(){
                cart.delete(v.itemId);
                renderCart();
            });

            cartEl.appendChild(wrap);
        });
    }

    function showErr(msg){
        var el = document.getElementById('afCreateErr');
        if (!el) return;
        el.textContent = msg;
        el.classList.add('show');
    }
    function hideErr(){
        var el = document.getElementById('afCreateErr');
        if (!el) return;
        el.textContent = '';
        el.classList.remove('show');
    }

    // Create order
    document.getElementById('afModalCreate')?.addEventListener('click', async function(){
        hideErr();

        if (cart.size === 0) {
            showErr('Add at least one item.');
            return;
        }

        var dest = (document.getElementById('afDestLocationId')?.value || '').trim();
        var src = (document.getElementById('afWarehouseLocationId')?.value || '').trim();

        if (!src) {
            showErr('No linked warehouse found for your account. Contact manager to link your affiliate to a warehouse.');
            return;
        }

        var items = Array.from(cart.values()).map(function(v){ return { itemId: v.itemId, quantity: v.qty }; });

        var fd = new FormData();
        var tokenEl = document.querySelector('input[name="__RequestVerificationToken"]');
        if (tokenEl) fd.append('__RequestVerificationToken', tokenEl.value);
        fd.append('sourceWarehouseLocationId', src);
        fd.append('destinationLocationId', dest);
        fd.append('itemsJson', JSON.stringify(items));

        try {
            var res = await fetch('?handler=CreateOrder', { method: 'POST', body: fd });
            var json = await res.json().catch(function(){ return null; });

            if (!res.ok || !json || json.success !== true) {
                var msg = (json && json.message) ? json.message : ('Error ' + res.status);
                showErr(msg);
                return;
            }

            closeModal();
            location.reload();
        } catch (e) {
            showErr(e.message || String(e));
        }
    });

    window.completeOrder = async function(ev, orderId){
        ev.preventDefault();
        ev.stopPropagation();
        if (!confirm('Complete this order?')) return;

        var fd = new FormData();
        var tokenEl = document.querySelector('input[name="__RequestVerificationToken"]');
        if (tokenEl) fd.append('__RequestVerificationToken', tokenEl.value);
        fd.append('orderId', orderId);

        var res = await fetch('?handler=CompleteOrder', { method: 'POST', body: fd });
        var json = await res.json().catch(function(){ return null; });
        if (!res.ok || !json || json.success !== true) {
            alert((json && json.message) ? json.message : ('Error ' + res.status));
            return;
        }
        location.reload();
    };

    window.cancelOrder = async function(ev, orderId){
        ev.preventDefault();
        ev.stopPropagation();
        if (!confirm('Cancel this order? Inventory will be restored.')) return;

        var fd = new FormData();
        var tokenEl = document.querySelector('input[name="__RequestVerificationToken"]');
        if (tokenEl) fd.append('__RequestVerificationToken', tokenEl.value);
        fd.append('orderId', orderId);

        var res = await fetch('?handler=CancelOrder', { method: 'POST', body: fd });
        var json = await res.json().catch(function(){ return null; });
        if (!res.ok || !json || json.success !== true) {
            alert((json && json.message) ? json.message : ('Error ' + res.status));
            return;
        }
        location.reload();
    };

    renderCart();
})();
</script>
}
